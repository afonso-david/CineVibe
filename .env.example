# Configurações do CineVibe
# Copie este ficheiro para .env e configure os valores

# Base de Dados MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=sua_senha_mysql
DB_NAME=cinevibe

# Configurações de Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu_email@gmail.com
EMAIL_PASSWORD=sua_senha_de_app
EMAIL_USE_TLS=True

# Chave Secreta da Aplicação (mude para produção)
SECRET_KEY=troca_isto_por_uma_chave_secreta_e_complexa

# Modo de Debug
DEBUG=True