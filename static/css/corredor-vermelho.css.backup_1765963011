/* ============================================
   DIVISÕES VERMELHAS - VERTICAL E HORIZONTAL
============================================ */

/* Override completo do corredor central VERTICAL */
.wide-center-aisle {
  width: 8px !important;
  height: 22px !important;
  background: transparent !important;
  position: relative !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
}

/* Traços vermelhos verticais no corredor */
.wide-center-aisle::before {
  content: '' !important;
  position: absolute !important;
  top: 0 !important;
  left: 50% !important;
  transform: translateX(-50%) !important;
  width: 2px !important;
  height: 100% !important;
  background: repeating-linear-gradient(
    to bottom,
    #ff0000 0px,
    #ff0000 4px,
    transparent 4px,
    transparent 8px
  ) !important;
  border-radius: 1px !important;
  z-index: 10 !important;
}

/* Linha divisória adicional horizontal */
.wide-center-aisle::after {
  content: '' !important;
  position: absolute !important;
  top: 50% !important;
  left: 0 !important;
  transform: translateY(-50%) !important;
  width: 100% !important;
  height: 1px !important;
  background: rgba(255, 0, 0, 0.3) !important;
  z-index: 5 !important;
}

/* ============================================
   SEPARAÇÃO HORIZONTAL ESTÉTICA
============================================ */

/* Container da sala com espaçamento para separação */
.wide-cinema-hall {
  position: relative !important;
  gap: 8px !important; /* Espaçamento entre filas */
}

/* Separação horizontal entre as filas do meio */
.wide-cinema-row:nth-child(6) {
  margin-bottom: 12px !important;
  position: relative !important;
}

/* Linha divisória horizontal estética (entre filas, não por cima) */
.wide-cinema-row:nth-child(6)::after {
  content: '' !important;
  position: absolute !important;
  top: calc(100% + 6px) !important;
  left: 0 !important;
  right: 0 !important;
  height: 2px !important;
  background: repeating-linear-gradient(
    to right,
    #ff0000 0px,
    #ff0000 4px,
    transparent 4px,
    transparent 8px
  ) !important;
  z-index: 5 !important;
  pointer-events: none !important;
}

/* Força aplicação em todos os contextos */
.wide-cinema-hall .wide-center-aisle,
.sala-dinamica .wide-center-aisle,
div.wide-center-aisle {
  width: 8px !important;
  background: transparent !important;
}

/* Responsivo para mobile */
@media (max-width: 768px) {
  .wide-center-aisle {
    width: 6px !important;
    height: 18px !important;
  }
  
  .wide-center-aisle::before {
    width: 1.5px !important;
  }
}

/* Animação sutil para os traços */
@keyframes pulse-red {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

.wide-center-aisle::before {
  animation: pulse-red 3s ease-in-out infinite !important;
}
/* ============================================
   CONFIGURAÇÕES PARA DIVISÃO ÚNICA
============================================ */

/* Garantir que a divisão seja visível */
.wide-cinema-hall {
  padding: 20px 40px !important;
  overflow: visible !important;
}

/* Configuração básica das filas */
.wide-cinema-row {
  position: relative !important;
}
