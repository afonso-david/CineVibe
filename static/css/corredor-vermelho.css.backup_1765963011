/* ============================================
   MELHORIAS ESTÉTICAS PARA DIVISÕES
============================================ */

/* Espaçamento adicional para criar separação visual clara */
.wide-cinema-row:nth-child(6) {
  border-bottom: 1px solid rgba(255, 0, 0, 0.1) !important;
  padding-bottom: 6px !important;
}

/* Sombra sutil para destacar a separação (dentro dos limites) */
.wide-cinema-row:nth-child(6)::before {
  content: '' !important;
  position: absolute !important;
  bottom: -6px !important;
  left: 0 !important;
  right: 0 !important;
  height: 1px !important;
  background: linear-gradient(
    to right,
    transparent 0%,
    rgba(255, 0, 0, 0.3) 20%,
    rgba(255, 0, 0, 0.5) 50%,
    rgba(255, 0, 0, 0.3) 80%,
    transparent 100%
  ) !important;
  z-index: 3 !important;
}

/* Melhorar o espaçamento geral da sala */
.wide-cinema-hall {
  padding: 30px 50px !important;
}

/* Garantir que os lugares não sejam afetados pelas divisões */
.wide-cinema-seat {
  z-index: 10 !important;
  position: relative !important;
}

/* Efeito de profundidade para a separação */
.wide-cinema-row:nth-child(7) {
  margin-top: 4px !important;
  position: relative !important;
}

.wide-cinema-row:nth-child(7)::before {
  content: '' !important;
  position: absolute !important;
  top: -10px !important;
  left: 0 !important;
  right: 0 !important;
  height: 1px !important;
  background: linear-gradient(
    to right,
    transparent 0%,
    rgba(255, 0, 0, 0.2) 20%,
    rgba(255, 0, 0, 0.4) 50%,
    rgba(255, 0, 0, 0.2) 80%,
    transparent 100%
  ) !important;
  z-index: 2 !important;
}
