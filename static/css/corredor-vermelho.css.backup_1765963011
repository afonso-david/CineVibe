/* ============================================
   MELHORIAS ESTÉTICAS PARA SAÍDAS DE EMERGÊNCIA
============================================ */

/* Posicionar saídas mais para os lados */
.wide-emergency-exit.left-exit {
  left: -80px !important; /* Mais para a esquerda */
  background: linear-gradient(135deg, #00d4aa, #00b894) !important;
  border: 2px solid #00e676 !important;
  box-shadow: 0 4px 15px rgba(0, 212, 170, 0.3) !important;
}

.wide-emergency-exit.right-exit {
  right: -80px !important; /* Mais para a direita */
  background: linear-gradient(135deg, #00d4aa, #00b894) !important;
  border: 2px solid #00e676 !important;
  box-shadow: 0 4px 15px rgba(0, 212, 170, 0.3) !important;
}

/* CAMINHO EM "L" - COMO NO TRACEJADO VERMELHO */

/* PARTE VERTICAL - Desce da porta */
.wide-emergency-exit.left-exit::after {
  content: '' !important;
  position: absolute !important;
  top: 100% !important; /* Começa logo abaixo da porta */
  left: 50% !important;
  transform: translateX(-50%) !important;
  width: 3px !important;
  height: 60px !important; /* Desce verticalmente */
  background: repeating-linear-gradient(
    to bottom,
    #ff0000 0px,
    #ff0000 4px,
    transparent 4px,
    transparent 8px
  ) !important;
  z-index: 5 !important;
}

.wide-emergency-exit.right-exit::after {
  content: '' !important;
  position: absolute !important;
  top: 100% !important; /* Começa logo abaixo da porta */
  left: 50% !important;
  transform: translateX(-50%) !important;
  width: 3px !important;
  height: 60px !important; /* Desce verticalmente */
  background: repeating-linear-gradient(
    to bottom,
    #ff0000 0px,
    #ff0000 4px,
    transparent 4px,
    transparent 8px
  ) !important;
  z-index: 5 !important;
}

/* PARTE HORIZONTAL - Vai para a sala */
.wide-emergency-exit.left-exit::before {
  content: '' !important;
  position: absolute !important;
  top: calc(100% + 60px) !important; /* No final da parte vertical */
  left: 50% !important;
  width: 80px !important; /* Vai horizontalmente para a direita */
  height: 3px !important;
  background: repeating-linear-gradient(
    to right,
    #ff0000 0px,
    #ff0000 6px,
    transparent 6px,
    transparent 12px
  ) !important;
  z-index: 5 !important;
}

.wide-emergency-exit.right-exit::before {
  content: '' !important;
  position: absolute !important;
  top: calc(100% + 60px) !important; /* No final da parte vertical */
  right: 50% !important;
  width: 80px !important; /* Vai horizontalmente para a esquerda */
  height: 3px !important;
  background: repeating-linear-gradient(
    to left,
    #ff0000 0px,
    #ff0000 6px,
    transparent 6px,
    transparent 12px
  ) !important;
  z-index: 5 !important;
}

/* Manter o ícone original da porta (não alterar) */

/* Efeito hover para linha verde VERTICAL */
.wide-emergency-exit:hover {
  transform: scale(1.1) !important;
  box-shadow: 0 6px 20px rgba(0, 212, 170, 0.5) !important;
  border-color: #00ff88 !important;
}

/* Hover na parte vertical do caminho em "L" */
.wide-emergency-exit:hover::after {
  background: repeating-linear-gradient(
    to bottom,
    #ff4444 0px,
    #ff4444 4px,
    transparent 4px,
    transparent 8px
  ) !important;
  width: 4px !important;
}

/* Hover na parte horizontal do caminho em "L" */
.wide-emergency-exit:hover::before {
  background: repeating-linear-gradient(
    to right,
    #ff4444 0px,
    #ff4444 6px,
    transparent 6px,
    transparent 12px
  ) !important;
  height: 4px !important;
}

/* Sombra ambiente para simular iluminação de emergência */
.wide-emergency-exit {
  position: relative !important;
}

.wide-emergency-exit::before {
  box-shadow: 0 0 10px rgba(0, 230, 118, 0.4) !important;
}

/* Responsividade para caminho em "L" */
@media (max-width: 768px) {
  .wide-emergency-exit.left-exit {
    left: -60px !important;
  }
  
  .wide-emergency-exit.right-exit {
    right: -60px !important;
  }
  
  /* Parte vertical menor */
  .wide-emergency-exit.left-exit::after,
  .wide-emergency-exit.right-exit::after {
    height: 40px !important;
    width: 2px !important;
  }
  
  /* Parte horizontal menor */
  .wide-emergency-exit.left-exit::before,
  .wide-emergency-exit.right-exit::before {
    top: calc(100% + 40px) !important;
    width: 60px !important;
    height: 2px !important;
  }
}

@media (max-width: 480px) {
  .wide-emergency-exit.left-exit {
    left: -50px !important;
  }
  
  .wide-emergency-exit.right-exit {
    right: -50px !important;
  }
  
  /* Caminho em "L" ainda menor */
  .wide-emergency-exit.left-exit::after,
  .wide-emergency-exit.right-exit::after {
    height: 30px !important;
    width: 2px !important;
  }
  
  .wide-emergency-exit.left-exit::before,
  .wide-emergency-exit.right-exit::before {
    top: calc(100% + 30px) !important;
    width: 50px !important;
    height: 2px !important;
  }
}
