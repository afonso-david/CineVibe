  background: linear-gradient(135deg, rgba(255, 61, 113, 0.15), rgba(255, 61, 113, 0.1));
  border: 2px solid rgba(255, 61, 113, 0.3);
  border-radius: var(--border-radius);
  color: #FF3D71;
  font-weight: 600;
  cursor: pointer;
  transition: var(--transition);
  font-family: 'Poppins', sans-serif;
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

.btn-limpar-selecoes:hover {
  background: linear-gradient(135deg, rgba(255, 61, 113, 0.25), rgba(255, 61, 113, 0.15));
  border-color: #FF3D71;
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(255, 61, 113, 0.3);
}

.btn-limpar-selecoes:active {
  transform: translateY(0);
}

