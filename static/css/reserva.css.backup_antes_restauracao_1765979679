/* Lugares pré-selecionados automaticamente */
.wide-cinema-seat.selected:not(.manual-selected) {
  background: linear-gradient(135deg, #ffd700, #ffb347, #ff8c00) !important;
  border-color: #ffd700 !important;
  transform: translateY(-2px) scale(1.05) !important;
  box-shadow: 
    0 6px 15px rgba(255, 215, 0, 0.4),
    0 0 12px rgba(255, 215, 0, 0.3) !important;
  z-index: 50;
  animation: preSelectedPulse 2s infinite ease-in-out;
}

/* Animação sutil para lugares pré-selecionados */
@keyframes preSelectedPulse {
  0%, 100% {
    box-shadow: 0 6px 15px rgba(255, 215, 0, 0.4), 0 0 12px rgba(255, 215, 0, 0.3);
  }
  50% {
    box-shadow: 0 8px 20px rgba(255, 215, 0, 0.6), 0 0 18px rgba(255, 215, 0, 0.4);
  }
}

/* Lugares selecionados manualmente */
.wide-cinema-seat.selected.manual-selected {
  background: linear-gradient(135deg, #ffd700, #ffb347, #ff8c00) !important;
  border-color: #ffd700 !important;
  transform: translateY(-3px) scale(1.1) !important;
  box-shadow: 
    0 8px 20px rgba(255, 215, 0, 0.6),
    0 0 15px rgba(255, 215, 0, 0.4) !important;
  z-index: 100;
  animation: none !important;
}

/* Ícone de confirmação para todos os selecionados */
.wide-cinema-seat.selected::after {
  content: '✓' !important;
  color: #000 !important;
  font-size: 11px !important;
  font-weight: 900 !important;
  text-shadow: 0 1px 2px rgba(255, 255, 255, 0.3) !important;
}

/* Lugares ocupados - apenas com dados reais */
.wide-cinema-seat.occupied {
  background: linear-gradient(145deg, rgba(50, 50, 50, 0.9), rgba(30, 30, 30, 0.8)) !important;
  border-color: rgba(255, 255, 255, 0.3) !important;
  cursor: not-allowed !important;
  pointer-events: none !important;
  opacity: 0.8;
}

.wide-cinema-seat.occupied::after {
  content: '✕' !important;
  color: rgba(255, 255, 255, 1) !important;
  font-size: 14px !important;
  font-weight: 900 !important;
  text-shadow: 0 0 3px rgba(0, 0, 0, 0.8) !important;
  z-index: 10 !important;
}

.wide-cinema-seat.occupied:hover {
  transform: none !important;
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.4) !important;
  cursor: not-allowed !important;
}

/* Melhorar legenda */
.legenda-seat.selecionado {
  background: linear-gradient(135deg, #ffd700, #ffb347);
  border: 2px solid #ffd700;
  animation: preSelectedPulse 2s infinite ease-in-out;
}

/* Responsividade das animações */
@media (max-width: 768px) {
  .wide-cinema-seat.selected:not(.manual-selected) {
    animation-duration: 3s;
  }
}

@media (prefers-reduced-motion: reduce) {
  .wide-cinema-seat.selected:not(.manual-selected),
  .legenda-seat.selecionado {
    animation: none !important;
  }
