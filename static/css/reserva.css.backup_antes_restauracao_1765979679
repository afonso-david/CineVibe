  border: 3px solid rgba(0, 230, 118, 0.4);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0A0E27;
  font-size: 18px;
  font-weight: 900;
  box-shadow: 
