/* Container para os botões de ação dos lugares */
.lugares-acoes {
  display: flex;
  gap: 15px;
  justify-content: center;
  align-items: center;
  flex-wrap: wrap;
}

/* Botão para limpar seleções */
.btn-limpar-selecoes {
