/* 
============================================
   PROGRESS BAR & LOADING EFFECTS
============================================ */
.progress-container {
  width: 100%;
  height: 6px;
  background: rgba(0, 217, 255, 0.1);
  border-radius: 3px;
  margin: 20px 0;
  overflow: hidden;
  position: relative;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--primary), var(--secondary));
  border-radius: 3px;
  transition: width 0.5s ease;
  position: relative;
}

.progress-bar::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(255, 255, 255, 0.4) 50%, 
    transparent 100%
  );
  animation: progressShine 2s infinite linear;
}

@keyframes progressShine {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}

/* ============================================
   FLOATING PARTICLES EFFECT
============================================ */
.particles-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 1;
  overflow: hidden;
}

.particle {
  position: absolute;
  width: 4px;
  height: 4px;
  background: rgba(0, 217, 255, 0.6);
  border-radius: 50%;
  animation: float 6s infinite linear;
}

.particle:nth-child(2n) {
  background: rgba(255, 214, 10, 0.4);
  animation-duration: 8s;
}

.particle:nth-child(3n) {
  background: rgba(255, 61, 113, 0.3);
  animation-duration: 10s;
}

@keyframes float {
  0% {
    transform: translateY(100vh) rotate(0deg);
    opacity: 0;
  }
  10% {
    opacity: 1;
  }
  90% {
    opacity: 1;
  }
  100% {
    transform: translateY(-100px) rotate(360deg);
    opacity: 0;
  }
}

/* ============================================
   ENHANCED TOOLTIPS
============================================ */
.tooltip {
  position: relative;
  display: inline-block;
}

.tooltip .tooltiptext {
  visibility: hidden;
  width: 200px;
  background: linear-gradient(135deg, rgba(10, 14, 39, 0.95), rgba(20, 27, 61, 0.95));
  color: var(--text-primary);
  text-align: center;
  border-radius: var(--border-radius);
  padding: 12px 16px;
  position: absolute;
  z-index: 1000;
  bottom: 125%;
  left: 50%;
  margin-left: -100px;
  opacity: 0;
  transition: var(--transition);
  border: 1px solid rgba(0, 217, 255, 0.3);
  box-shadow: var(--shadow-lg);
  font-size: 0.9rem;
  font-weight: 500;
}

.tooltip .tooltiptext::after {
  content: "";
  position: absolute;
  top: 100%;
  left: 50%;
  margin-left: -5px;
  border-width: 5px;
  border-style: solid;
  border-color: rgba(10, 14, 39, 0.95) transparent transparent transparent;
}

.tooltip:hover .tooltiptext {
  visibility: visible;
  opacity: 1;
  transform: translateY(-5px);
}

/* ============================================
   MICRO INTERACTIONS
============================================ */
.btn-micro-bounce {
  animation: microBounce 0.6s ease;
}

@keyframes microBounce {
  0%, 20%, 50%, 80%, 100% {
    transform: translateY(0);
  }
  40% {
    transform: translateY(-8px);
  }
  60% {
    transform: translateY(-4px);
  }
}

.shake-error {
  animation: shakeError 0.5s ease-in-out;
}

@keyframes shakeError {
  0%, 100% { transform: translateX(0); }
  10%, 30%, 50%, 70%, 90% { transform: translateX(-5px); }
  20%, 40%, 60%, 80% { transform: translateX(5px); }
}

/* ============================================
   ENHANCED FORM INPUTS
============================================ */
.form-group-enhanced {
  position: relative;
  margin-bottom: 25px;
}

.form-input-enhanced {
  width: 100%;
  padding: 18px 20px;
  background: rgba(10, 14, 39, 0.8);
  border: 2px solid rgba(0, 217, 255, 0.2);
  border-radius: var(--border-radius);
  color: var(--text-primary);
  font-size: 1rem;
  font-family: 'Poppins', sans-serif;
  transition: var(--transition);
  outline: none;
}

.form-input-enhanced:focus {
  border-color: var(--primary);
  box-shadow: 0 0 20px rgba(0, 217, 255, 0.3);
  background: rgba(10, 14, 39, 0.9);
}

.form-input-enhanced::placeholder {
  color: var(--text-muted);
  font-weight: 400;
}

.form-label-enhanced {
  position: absolute;
  top: -12px;
  left: 15px;
  background: var(--bg-dark);
  padding: 0 8px;
  color: var(--primary);
  font-size: 0.85rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1px;
}

/* ============================================
   NOTIFICATION SYSTEM
============================================ */
.notification {
  position: fixed;
  top: 20px;
  right: 20px;
  padding: 16px 24px;
  border-radius: var(--border-radius);
  color: white;
  font-weight: 600;
  z-index: 10000;
  transform: translateX(400px);
  transition: var(--transition);
  box-shadow: var(--shadow-lg);
  backdrop-filter: blur(10px);
}

.notification.show {
  transform: translateX(0);
}

.notification.success {
  background: linear-gradient(135deg, rgba(0, 230, 118, 0.9), rgba(0, 200, 100, 0.9));
  border: 1px solid rgba(0, 230, 118, 0.3);
}

.notification.error {
  background: linear-gradient(135deg, rgba(255, 61, 113, 0.9), rgba(220, 50, 100, 0.9));
  border: 1px solid rgba(255, 61, 113, 0.3);
}

.notification.info {
  background: linear-gradient(135deg, rgba(0, 217, 255, 0.9), rgba(0, 180, 220, 0.9));
  border: 1px solid rgba(0, 217, 255, 0.3);
}/* ====
========================================
   BACKGROUND ANIMATED ELEMENTS
============================================ */
.reserva-right::after {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(0, 217, 255, 0.03) 0%, transparent 70%);
  /* animation: backgroundPulse 8s infinite ease-in-out; */
  pointer-events: none;
}

@keyframes backgroundPulse {
  0%, 100% {
    transform: scale(1) rotate(0deg);
