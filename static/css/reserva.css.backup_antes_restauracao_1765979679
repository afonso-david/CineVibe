/* ============================================
   CORREDOR CENTRAL MELHORADO
============================================ */
.corredor-central {
  width: 25px;
  height: 35px;
  margin: 0 8px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.corredor-central::before {
  content: '';
  position: absolute;
  top: 0;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 3px;
  background: linear-gradient(to bottom, 
    transparent 0%,
    rgba(255, 61, 113, 0.3) 20%,
    rgba(255, 61, 113, 0.8) 50%,
    rgba(255, 61, 113, 0.3) 80%,
    transparent 100%
  );
  border-radius: 2px;
  box-shadow: 0 0 8px rgba(255, 61, 113, 0.4);
