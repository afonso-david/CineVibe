    inset 0 1px 0 rgba(255, 255, 255, 0.3);
  position: relative;
  cursor: help;
  transition: all 0.3s ease;
}

.saida-emergencia::before {
  content: '';
  position: absolute;
  top: -2px;
  left: -2px;
  right: -2px;
  bottom: -2px;
  background: linear-gradient(135deg, rgba(0, 230, 118, 0.6), rgba(0, 200, 100, 0.4));
  border-radius: 14px;
  z-index: -1;
  opacity: 0;
