.notificacao-close:hover {
  background: rgba(255, 255, 255, 0.2);
}

/* ============================================
   FIM DAS MELHORIAS
============================================ *//* 
============================================
   LUGARES DE CASAL EM DUPLAS
============================================ */

/* Indicador visual de que são pares */
.wide-cinema-seat.couple-seat {
  position: relative;
}

/* Conectar visualmente os pares de casal */
.wide-cinema-seat.couple-seat + .wide-cinema-seat.couple-seat {
  margin-left: -2px !important;
  border-left: none !important;
  border-top-left-radius: 0 !important;
  border-bottom-left-radius: 0 !important;
}

.wide-cinema-seat.couple-seat:has(+ .wide-cinema-seat.couple-seat) {
  border-top-right-radius: 0 !important;
  border-bottom-right-radius: 0 !important;
  border-right: 1px solid rgba(255, 20, 147, 0.5) !important;
}

/* Efeito de hover para o par completo */
.wide-cinema-seat.couple-seat:hover + .wide-cinema-seat.couple-seat,
.wide-cinema-seat.couple-seat:has(+ .wide-cinema-seat.couple-seat:hover) {
  transform: translateY(-3px) scale(1.05) !important;
  box-shadow: 
    0 8px 25px rgba(255, 20, 147, 0.6),
    0 0 30px rgba(255, 20, 147, 0.4) !important;
}

/* Quando um lugar de casal é selecionado, destacar o par */
.wide-cinema-seat.couple-seat.selected + .wide-cinema-seat.couple-seat,
.wide-cinema-seat.couple-seat:has(+ .wide-cinema-seat.couple-seat.selected) {
  border-color: #FFD60A !important;
  box-shadow: 
    0 6px 20px rgba(255, 214, 10, 0.4),
    0 0 25px rgba(255, 214, 10, 0.3) !important;
}

/* Indicador de par no canto */
.wide-cinema-seat.couple-seat::after {
  content: '';
  position: absolute;
  top: -3px;
  right: -3px;
  width: 8px;
  height: 8px;
  background: rgba(255, 20, 147, 0.8);
  border-radius: 50%;
  border: 1px solid white;
  z-index: 5;
}

/* Esconder o indicador do segundo lugar do par */
.wide-cinema-seat.couple-seat + .wide-cinema-seat.couple-seat::after {
  display: none;
}

