/* ============================================
   ENHANCED STEP INDICATORS
============================================ */
.step-indicator {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20px;
  margin-bottom: 30px;
  padding: 20px;
  background: rgba(0, 217, 255, 0.02);
  border-radius: var(--border-radius);
  border: 1px solid rgba(0, 217, 255, 0.1);
}

.step-dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: rgba(122, 139, 163, 0.3);
  transition: var(--transition);
  position: relative;
}

.step-dot.active {
  background: linear-gradient(135deg, var(--primary), var(--secondary));
  box-shadow: 0 0 15px rgba(0, 217, 255, 0.5);
  animation: stepPulse 2s infinite ease-in-out;
}

.step-dot.completed {
  background: var(--success);
  box-shadow: 0 0 10px rgba(0, 230, 118, 0.4);
}

@keyframes stepPulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.3);
  }
}

.step-line {
  width: 40px;
  height: 2px;
  background: rgba(122, 139, 163, 0.2);
  transition: var(--transition);
}

.step-line.active {
  background: linear-gradient(90deg, var(--primary), var(--secondary));
  box-shadow: 0 0 8px rgba(0, 217, 255, 0.3);
}

/* ============================================
   CINEMA SEAT LEGEND
============================================ */
.seat-legend {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 25px;
  margin: 25px 0;
  padding: 20px;
  background: rgba(0, 217, 255, 0.02);
  border-radius: var(--border-radius);
  border: 1px solid rgba(0, 217, 255, 0.1);
  flex-wrap: wrap;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 0.9rem;
  font-weight: 500;
  color: var(--text-secondary);
}

.legend-seat {
  width: 20px;
  height: 20px;
  border-radius: 6px;
  border: 2px solid;
}

.legend-seat.available {
  background: linear-gradient(145deg, rgba(26, 35, 80, 0.9), rgba(15, 20, 50, 0.9));
  border-color: rgba(0, 217, 255, 0.3);
}

.legend-seat.selected {
  background: linear-gradient(135deg, #FFD60A, #FFB703);
  border-color: #FFD60A;
}

.legend-seat.occupied {
  background: transparent;
  border-color: rgba(255, 255, 255, 0.15);
  position: relative;
}

.legend-seat.occupied::after {
  content: '✕';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: white;
  font-size: 12px;
  font-weight: 900;
}

.legend-seat.accessible {
  background: rgba(0, 230, 118, 0.12);
  border-color: var(--success);
}

/* ============================================
   ENHANCED LOADING STATES
============================================ */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(10, 14, 39, 0.9);
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10000;
  opacity: 0;
  visibility: hidden;
  transition: var(--transition);
}

.loading-overlay.show {
  opacity: 1;
  visibility: visible;
}

.loading-spinner {
  width: 60px;
  height: 60px;
  border: 4px solid rgba(0, 217, 255, 0.2);
  border-top: 4px solid var(--primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  position: relative;
}

.loading-spinner::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 30px;
  height: 30px;
  border: 2px solid rgba(255, 214, 10, 0.3);
  border-top: 2px solid var(--secondary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite reverse;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20px;
  color: var(--text-primary);
  font-size: 1.1rem;
  font-weight: 600;
  text-align: center;
  animation: loadingPulse 1.5s infinite ease-in-out;
}

@keyframes loadingPulse {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}

/* ============================================
   ENHANCED HOVER EFFECTS
============================================ */
.hover-glow {
  position: relative;
  overflow: hidden;
}

.hover-glow::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, 
    transparent, 
    rgba(0, 217, 255, 0.1), 
    transparent
  );
  transition: left 0.5s ease;
}

.hover-glow:hover::before {
  left: 100%;
}

