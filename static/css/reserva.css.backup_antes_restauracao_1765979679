  box-shadow: 
    0 12px 35px rgba(0, 230, 118, 0.6),
    0 0 30px rgba(0, 230, 118, 0.3),
    inset 0 1px 0 rgba(255, 255, 255, 0.4);
}

.saida-emergencia i {
  animation: exitPulse 2s infinite ease-in-out;
}

@keyframes exitPulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.1);
  }
}

/* Posicionamento específico das saídas */
.saidas-superiores {
  margin-bottom: 15px;
}

.saidas-inferiores {
  margin-top: 15px;
}

/* ============================================
   FILA MELHORADA COM LABELS DUPLAS
============================================ */
.fila {
  display: flex;
  align-items: center;
  gap: 6px;
  position: relative;
  padding: 0 10px;
  min-width: 100%;
  justify-content: center;
}

.fila-label {
