<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reserva de Bilhetes | CineVibe</title>

  <!-- Fontes -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700;900&display=swap" rel="stylesheet">
  
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <!-- CSS -->
  <link rel="stylesheet" href="{{ url_for('static', filename='css/style.css') }}">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/reserva.css') }}">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/corredor-vermelho.css') }}">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/produtos-bar-premium.css') }}">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/resumo-finalizacao-premium.css') }}">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/modal-lugares-premium.css') }}">

</head>
<body>
  <!-- Header -->
  <header>
    <div class="top-nav">
      <div class="nav-left">
        <img src="{{ url_for('static', filename='imgs/Logo/logo8 sem fundo.png') }}" alt="logo CineVibe" class="logo">
      </div>

      <div class="nav-right">
        <div class="search-container">
          <input type="text" placeholder="Procurar Filmes...">
          <img src="{{ url_for('static', filename='imgs/icons/OIP-removebg-preview (4).png') }}" alt="search_icon" class="search_icon">
        </div>

        <div class="user-icon">
    {% if logged_in %}
        <a href="{{ url_for('perfil') }}">
            <img src="{{ url_for('static', filename=avatar) }}" class="user-pic" alt="Perfil">
        </a>
    {% else %}
        <a href="{{ url_for('login') }}">
            <img src="{{ url_for('static', filename='imgs/icons/user_icon34-removebg-preview.png') }}" alt="Login">
        </a>
    {% endif %}
</div>
      </div>
    </div>
  </header>

  <!-- Navegação -->
  <nav class="nav-center">
    <a href="{{ url_for('home') }}">Home</a>
    <a href="{{ url_for('filmes') }}">Filmes</a>
    <a href="{{ url_for('cinemas') }}">Cinemas</a>
    <a href="{{ url_for('cine_acessivel') }}">CineAcessível</a>
    <a href="{{ url_for('bar') }}">Bar</a>
    <a href="{{ url_for('beneficios') }}">Benefícios</a>
    <a href="{{ url_for('sessao') }}">Sessão Só Para Ti</a>
    <a href="{{ url_for('contactos') }}">Contactos</a>
  </nav>

  <div class="page-wrapper">
    <!-- Main Content -->
    <main class="reserva-main-container">
      <div class="reserva-layout">
        
        <!-- Sidebar (oculta inicialmente) -->
        <div class="reserva-left">
          <div class="info-panel">
            <div class="filme-info">
              <h3>{{ filme.titulo }}</h3>
              <div class="sessao-info">
                <h4>Sessão</h4>
                <div class="sessao-meta">
                  <div class="meta-row">
                    <span class="meta-label">Data:</span>
                    <span class="meta-value">{{ data_sessao }}</span>
                  </div>
                  <div class="meta-row">
                    <span class="meta-label">Hora:</span>
                    <span class="meta-value">{{ horario.hora_str if horario else 'N/A' }}</span>
                  </div>
                  <div class="meta-row">
                    <span class="meta-label">Cinema:</span>
                    <span class="meta-value">{{ cinema.nome }}</span>
                  </div>
                  <div class="meta-row">
                    <span class="meta-label">Sala:</span>
                    <span class="meta-value">{{ sala.nome_sala if sala else 'N/A' }}</span>
                  </div>
                </div>
              </div>
              
              <div class="resumo-reserva">
                <h4>Resumo</h4>
                <div class="resumo-content">
                  <div class="resumo-item">
                    <span class="resumo-label">Bilhetes:</span>
                    <span class="resumo-value" id="resumo-bilhetes">0</span>
                  </div>
                  <div class="resumo-item">
                    <span class="resumo-label">Lugares:</span>
                    <span class="resumo-value" id="resumo-lugares-sidebar">-</span>
                  </div>
                  <div class="resumo-item">
                    <span class="resumo-label">Bar:</span>
                    <span class="resumo-value" id="resumo-bar-sidebar">0.00€</span>
                  </div>
                  <div class="resumo-item total">
                    <span class="resumo-label">Total:</span>
                    <span class="resumo-value" id="resumo-total-sidebar">0.00€</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Main Content Area -->
        <div class="reserva-right">
          <div class="reserva-form-container">

            <!-- PASSO 1: QUANTIDADE DE BILHETES -->
            <div id="passo-bilhetes" class="form-step active">
              <div class="step-header">
                <h2>1. Quantos bilhetes?</h2>
                <p>Selecione a quantidade de bilhetes desejada</p>
              </div>
              
              <div class="bilhetes-grid">
                <button class="btn-bilhete" data-qtd="1">
                  <span class="bilhete-numero">1</span>
                  <span class="bilhete-label">Bilhete</span>
                </button>
                <button class="btn-bilhete" data-qtd="2">
                  <span class="bilhete-numero">2</span>
                  <span class="bilhete-label">Bilhetes</span>
                </button>
                <button class="btn-bilhete" data-qtd="3">
                  <span class="bilhete-numero">3</span>
                  <span class="bilhete-label">Bilhetes</span>
                </button>
                <button class="btn-bilhete" data-qtd="4">
                  <span class="bilhete-numero">4</span>
                  <span class="bilhete-label">Bilhetes</span>
                </button>
                <button class="btn-bilhete" data-qtd="5">
                  <span class="bilhete-numero">5</span>
                  <span class="bilhete-label">Bilhetes</span>
                </button>
                <button class="btn-bilhete" data-qtd="6">
                  <span class="bilhete-numero">6</span>
                  <span class="bilhete-label">Bilhetes</span>
                </button>
              </div>

              <!-- Quantidade Custom -->
              <div class="quantidade-custom-wrapper">
                <p class="quantidade-label">Ou escolha outra quantidade</p>
                <div class="quantidade-controls">
                  <button type="button" id="btn-menos-bilhetes" class="btn-qty-mini">-</button>
                  <input type="number" id="quantidade-bilhetes" class="input-qty-mini" min="1" max="50" value="1" />
                  <button type="button" id="btn-mais-bilhetes" class="btn-qty-mini">+</button>
                </div>
                <p class="quantidade-hint">Selecione de 1 a 50 bilhetes</p>
              </div>

              <!-- Botão Continuar -->
              <div class="step-actions-wrapper">
                <button id="continuar-lugares" class="btn-continuar-lugares" disabled>
                  Continuar para Lugares
                  <span class="btn-arrow"><i class="fas fa-arrow-right"></i></span>
                </button>

</body>
</html>