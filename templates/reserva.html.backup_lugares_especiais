    function preSeleccionarLugaresConsecutivos(filas, ocupados) {
      console.log('preSeleccionarLugaresConsecutivos chamada com:', quantidadeBilhetes, 'bilhetes');
      if (quantidadeBilhetes === 0) {
        console.log('Quantidade de bilhetes é 0, saindo...');
        return;
      }
      
      // Limpar seleções anteriores
      lugaresSelecionados = [];
      document.querySelectorAll('.wide-cinema-seat.selected').forEach(seat => {
        seat.classList.remove('selected');
      });
      console.log('Seleções anteriores limpas');
      
      // Encontrar sequências de lugares livres consecutivos
      const sequenciasLivres = [];
      
      filas.forEach(fila => {
        // Verificar diferentes áreas da sala para mais variedade (dinâmico)
        const layoutAtual = window.currentLayoutSala || { distribuicao: { lateral: 6, centro: 8 }, lugaresporFila: 28 };
        const lateral = layoutAtual.distribuicao.lateral;
        const centro = layoutAtual.distribuicao.centro;
        const lugaresTotaisFila = layoutAtual.lugaresporFila || 28;
        
        console.log(`Fila ${fila}: lateral=${lateral}, centro=${centro}, total=${lugaresTotaisFila}`);
        const areas = [
          { inicio: 1, fim: lateral, tipo: 'lateral-esquerda' },
          { inicio: lateral + 1, fim: lateral + centro, tipo: 'centro-esquerda' },
          { inicio: lateral + centro + 1, fim: lateral + (centro * 2), tipo: 'centro-direita' },
          { inicio: lateral + (centro * 2) + 1, fim: lugaresTotaisFila, tipo: 'lateral-direita' }
        ];
        
        areas.forEach(area => {
          for (let inicio = area.inicio; inicio <= area.fim - quantidadeBilhetes + 1; inicio++) {
            let sequenciaValida = true;
            const sequencia = [];
            
            // Verificar se todos os lugares da sequência estão livres
            for (let i = 0; i < quantidadeBilhetes; i++) {
              const lugarId = `${fila}${inicio + i}`;
              if (ocupados.includes(lugarId)) {
                sequenciaValida = false;
                break;
              }
              sequencia.push(lugarId);
            }
            
            if (sequenciaValida) {
              sequenciasLivres.push({
                fila: fila,
                lugares: sequencia,
                inicio: inicio,
                filaIndex: filas.indexOf(fila),
                area: area.tipo
              });
            }
          }
        });
      });
      
      console.log('Sequências livres encontradas:', sequenciasLivres.length);
      
      if (sequenciasLivres.length > 0) {
        // Priorizar filas do meio dinamicamente
        const numFilas = filas.length;
        const indiceMeio = Math.floor(numFilas / 2);
        const filasPreferidas = [
          filas[indiceMeio - 1] || filas[0],
          filas[indiceMeio] || filas[0], 
          filas[indiceMeio + 1] || filas[0],
          filas[indiceMeio + 2] || filas[0]
        ].filter(f => f); // Remove undefined
        
        console.log('Filas preferidas calculadas:', filasPreferidas);
        let sequenciasPreferidas = [];
        
        // Sistema de pesos para seleção aleatória inteligente
        const sequenciasComPeso = [];
        
        sequenciasLivres.forEach(seq => {
          let peso = 1; // Peso base
          
          // Aumentar peso para filas preferidas
          if (filasPreferidas.includes(seq.fila)) {
            peso += 3;
          }
          
          // Aumentar peso para áreas centrais
          if (seq.area === 'centro-esquerda' || seq.area === 'centro-direita') {
            peso += 2;
          }
          
          // Reduzir peso se for a mesma área da última seleção (para variedade)
          if (ultimaAreaSelecionada && seq.area === ultimaAreaSelecionada) {
            peso = Math.max(1, peso - 2);
          }
          
          // Adicionar múltiplas cópias baseadas no peso
          for (let i = 0; i < peso; i++) {
            sequenciasComPeso.push(seq);
          }
        });
        
        // Escolher aleatoriamente considerando os pesos
        let sequenciaEscolhida = null;
        if (sequenciasComPeso.length > 0) {
          const indiceAleatorio = Math.floor(Math.random() * sequenciasComPeso.length);
          sequenciaEscolhida = sequenciasComPeso[indiceAleatorio];
          
          // Guardar a área selecionada para próxima vez
          ultimaAreaSelecionada = sequenciaEscolhida.area;
          
          console.log('Escolhida sequência aleatória ponderada:', sequenciaEscolhida);
          console.log('Área selecionada:', sequenciaEscolhida.area);
        }
        
        // Pré-selecionar os lugares
        console.log('Sequência escolhida:', sequenciaEscolhida);
        console.log('Total de sequências encontradas:', sequenciasLivres.length);
        
        sequenciaEscolhida.lugares.forEach(lugarId => {
          const lugarElement = document.querySelector(`[data-id="${lugarId}"]`);
          console.log('Tentando selecionar lugar:', lugarId, 'Elemento encontrado:', !!lugarElement);
          if (lugarElement && !lugarElement.classList.contains('occupied')) {
            lugarElement.classList.add('selected');
            lugaresSelecionados.push(lugarId);
            console.log('Lugar selecionado com sucesso:', lugarId);
          } else {
            console.log('Falha ao selecionar lugar:', lugarId, 'Ocupado:', lugarElement?.classList.contains('occupied'));
          }
        });
        
        // Atualizar display e habilitar botão
        atualizarDisplayLugares();
        document.getElementById('continuar-bar').disabled = false;
        
        console.log('Lugares pré-selecionados final:', lugaresSelecionados);
      }
    }
    
    function wideSelectSeat(seat) {
      if (seat.classList.contains('occupied')) return;
      
      const seatId = seat.dataset.id;
      
      // LUGARES DE CASAL: Tratar como duplas inseparáveis
      if (seat.classList.contains('couple-seat')) {
        handleCoupleSeatSelection(seat, seatId);
      } else {
        // Lógica normal para outros lugares
        handleNormalSeatSelection(seat, seatId);
      }
      
      atualizarDisplayLugares();
      document.getElementById('continuar-bar').disabled = lugaresSelecionados.length !== quantidadeBilhetes;
    }
    
    function handleCoupleSeatSelection(seat, seatId) {
      const couplePair = findCouplePair(seatId);
      
      if (!couplePair) {
        console.warn('Par de casal não encontrado para:', seatId);
        return;
      }
      
      const [seat1Id, seat2Id] = couplePair;
      const seat1 = document.querySelector(`[data-id="${seat1Id}"]`);
      const seat2 = document.querySelector(`[data-id="${seat2Id}"]`);
      
      if (!seat1 || !seat2) {
        console.warn('Lugares do par não encontrados:', seat1Id, seat2Id);
        return;
      }
      
      // Verificar se algum dos lugares está ocupado
      if (seat1.classList.contains('occupied') || seat2.classList.contains('occupied')) {
        return;
      }
      
      // Se qualquer um dos lugares está selecionado, desselecionar ambos
      if (seat1.classList.contains('selected') || seat2.classList.contains('selected')) {
        // Desselecionar ambos
        seat1.classList.remove('selected', 'manual-selected');
        seat2.classList.remove('selected', 'manual-selected');
        lugaresSelecionados = lugaresSelecionados.filter(id => id !== seat1Id && id !== seat2Id);
        console.log('Par de casal desselecionado:', seat1Id, seat2Id);
      } else {
        // Verificar se há espaço para selecionar o par (2 lugares)
        const espacoDisponivel = quantidadeBilhetes - lugaresSelecionados.length;
        
        if (espacoDisponivel >= 2) {
          // Limpar pré-seleções se necessário
          const hasAutoSelected = document.querySelector('.wide-cinema-seat.selected:not(.manual-selected)');
          if (hasAutoSelected) {
            document.querySelectorAll('.wide-cinema-seat.selected:not(.manual-selected)').forEach(s => {
              s.classList.remove('selected');
              lugaresSelecionados = lugaresSelecionados.filter(id => id !== s.dataset.id);
            });
          }
          
          // Selecionar ambos os lugares do par
          seat1.classList.add('selected', 'manual-selected');
          seat2.classList.add('selected', 'manual-selected');
          lugaresSelecionados.push(seat1Id, seat2Id);
          console.log('Par de casal selecionado:', seat1Id, seat2Id);
        }
      }
    }
    
    function handleNormalSeatSelection(seat, seatId) {
      // Se o lugar já está selecionado, desselecionar
      if (seat.classList.contains('selected')) {
        seat.classList.remove('selected', 'manual-selected');
        lugaresSelecionados = lugaresSelecionados.filter(id => id !== seatId);
      } else {
        // Verificar se há lugares pré-selecionados (automáticos)
        const hasAutoSelected = document.querySelector('.wide-cinema-seat.selected:not(.manual-selected)');
        
        if (hasAutoSelected) {
          // Se há pré-seleções, só permite selecionar se ainda há espaço
          if (lugaresSelecionados.length < quantidadeBilhetes) {
            seat.classList.add('selected', 'manual-selected');
            lugaresSelecionados.push(seatId);
          }
        } else {
          // Se não há pré-seleções, permite seleção normal
          if (lugaresSelecionados.length < quantidadeBilhetes) {
            seat.classList.add('selected', 'manual-selected');
            lugaresSelecionados.push(seatId);
          }
        }
      }
    }
    
    function findCouplePair(seatId) {
      // Definir os pares de lugares de casal - 6 DUPLAS em uma fila com espaçamento
      const couplePairs = [
        ['E3', 'E4'],   // Dupla 1
        ['E6', 'E7'],   // Dupla 2
        ['E9', 'E10'],  // Dupla 3
        ['E12', 'E13'], // Dupla 4
        ['E15', 'E16'], // Dupla 5
        ['E18', 'E19']  // Dupla 6
      ];
      
      // Encontrar o par que contém o lugar clicado
      return couplePairs.find(pair => pair.includes(seatId));
    }
    




    function atualizarDisplayLugares() {
      const display = document.getElementById('lugares-display');
      if (lugaresSelecionados.length === 0) {
