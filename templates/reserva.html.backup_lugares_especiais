    function resetarSelecaoLugares() {
      // Limpar todas as seleções visuais
      document.querySelectorAll('.wide-cinema-seat.selected').forEach(seat => {
        seat.classList.remove('selected', 'manual-selected');
      });
      
      // Limpar array de lugares selecionados
      lugaresSelecionados = [];
      
      // Atualizar display
      atualizarDisplayLugares();
      
      // Desabilitar botão continuar
      const btnContinuar = document.getElementById('continuar-bar');
      if (btnContinuar) {
        btnContinuar.disabled = true;
      }
    }
    


    function adicionarProduto(id, tipo) {
      if (!produtosBar[id]) {
        produtosBar[id] = { quantidade: 0, tipo: tipo };
      }
      produtosBar[id].quantidade++;
      
      atualizarControleProduto(id);
      atualizarVisualCard(id);
      atualizarResumo();
      
      // Efeito visual de adição
      const card = document.querySelector(`[data-produto-id="${id}"]`);
      if (card) {
        card.classList.add('bounce-effect');
        setTimeout(() => card.classList.remove('bounce-effect'), 400);
      }
    }

    function removerProduto(id, tipo) {
      if (produtosBar[id] && produtosBar[id].quantidade > 0) {
        produtosBar[id].quantidade--;
        if (produtosBar[id].quantidade === 0) {
          delete produtosBar[id];
        }
      }
      
      atualizarControleProduto(id);
      atualizarVisualCard(id);
      atualizarResumo();
    }

    function atualizarControleProduto(id) {
      const quantidade = produtosBar[id] ? produtosBar[id].quantidade : 0;
      const spanQuantidade = document.querySelector(`[data-id="${id}"].quantidade`);
      const btnMenos = document.querySelector(`[data-id="${id}"].btn-menos`);
      
      if (spanQuantidade) spanQuantidade.textContent = quantidade;
      if (btnMenos) btnMenos.disabled = quantidade === 0;
    }
    
    function atualizarVisualCard(id) {
      console.log('Atualizando visual do card:', id);
      const card = document.querySelector(`[data-produto-id="${id}"]`);
      const quantidade = produtosBar[id] ? produtosBar[id].quantidade : 0;
      
      console.log('Card encontrado:', card, 'Quantidade:', quantidade);
      
      if (card) {
        // Garantir que o card está visível
        card.style.opacity = '1';
        card.style.transform = 'translateY(0)';
        
        // Remover badge existente
        const existingBadge = card.querySelector('.quantidade-badge');
        if (existingBadge) {
          existingBadge.remove();
        }
        
        if (quantidade > 0) {
          card.classList.add('selected');
          
          // Criar novo badge
          const badge = document.createElement('div');
          badge.className = 'quantidade-badge';
          badge.textContent = quantidade;
          card.appendChild(badge);
        } else {
          card.classList.remove('selected');
        }
      }
    }

    function atualizarResumo() {
      // Atualizar bilhetes
      const resumoBilhetesQtd = document.getElementById('resumo-bilhetes-qtd');
      const resumoLugaresLista = document.getElementById('resumo-lugares-lista');
      const resumoBilhetesTotal = document.getElementById('resumo-bilhetes-total');
      const resumoPrecoUnitario = document.getElementById('resumo-preco-unitario');
      
      if (resumoBilhetesQtd) resumoBilhetesQtd.textContent = quantidadeBilhetes;
      if (resumoPrecoUnitario) resumoPrecoUnitario.textContent = precoUnitario.toFixed(2) + '€';
      
      const totalBilhetes = quantidadeBilhetes * precoUnitario;
      if (resumoBilhetesTotal) resumoBilhetesTotal.textContent = totalBilhetes.toFixed(2) + '€';
      
      if (resumoLugaresLista) {
        resumoLugaresLista.textContent = lugaresSelecionados.length > 0 ? lugaresSelecionados.join(', ') : 'Nenhum selecionado';
      }
      
      // Calcular total do bar
      let totalBar = 0;
      Object.keys(produtosBar).forEach(id => {
        const produto = produtosBar[id];
        // Aqui você precisaria do preço do produto - isso viria do backend
        // Por agora, vamos usar um preço exemplo
        const preco = 5.00; // Preço exemplo
        totalBar += produto.quantidade * preco;
      });
      
      // Atualizar sidebar
      if (resumoBilhetes) resumoBilhetes.textContent = quantidadeBilhetes;
      if (resumoLugaresSidebar) resumoLugaresSidebar.textContent = lugaresSelecionados.length > 0 ? lugaresSelecionados.join(', ') : '-';
      if (resumoBarSidebar) resumoBarSidebar.textContent = totalBar.toFixed(2) + '€';
      
      const totalGeral = totalBilhetes + totalBar;
      if (resumoTotalSidebar) resumoTotalSidebar.textContent = totalGeral.toFixed(2) + '€';
      
      // Atualizar total final
      const resumoTotalFinal = document.getElementById('resumo-total-final');
      if (resumoTotalFinal) resumoTotalFinal.textContent = totalGeral.toFixed(2) + '€';
      
      // Habilitar botão finalizar se tudo estiver preenchido
      const btnFinalizar = document.getElementById('finalizar-reserva');
      if (btnFinalizar) {
        const temBilhetes = quantidadeBilhetes > 0;
        const temLugares = lugaresSelecionados.length === quantidadeBilhetes;
        {% if not user_authenticated %}
        const temDados = document.getElementById('nome') && document.getElementById('nome').value.trim() !== '' &&
                        document.getElementById('email') && document.getElementById('email').value.trim() !== '';
        {% else %}
        const temDados = true;
        {% endif %}
        
        btnFinalizar.disabled = !(temBilhetes && temLugares && temDados);
      }
    }

    function atualizarResumoFinal() {
      // Mostrar seção do bar se houver produtos
      const resumoBarSection = document.getElementById('resumo-bar-section');
      const resumoBarProdutos = document.getElementById('resumo-bar-produtos');
      
      if (Object.keys(produtosBar).length > 0) {
        resumoBarSection.style.display = 'block';
        resumoBarProdutos.innerHTML = '';
        
        Object.keys(produtosBar).forEach(id => {
          const produto = produtosBar[id];
          const div = document.createElement('div');
          div.className = 'detail-row';
          div.innerHTML = `
            <span class="detail-label">${id}:</span>
            <span class="detail-value">${produto.quantidade}x</span>
          `;
          resumoBarProdutos.appendChild(div);
        });
      } else {
        resumoBarSection.style.display = 'none';
      }
      
      atualizarResumo();
    }

    function finalizarReserva() {
      // Validar se todos os dados necessários estão preenchidos
      if (quantidadeBilhetes === 0) {
        alert('Por favor, selecione pelo menos um lugar.');
        return;
      }
      
      {% if not user_authenticated %}
      // Validar dados pessoais para usuários não logados
      const nome = document.getElementById('nome').value.trim();
      const email = document.getElementById('email').value.trim();
      const telefone = document.getElementById('telefone').value.trim();
      
      if (!nome || !email) {
        alert('Por favor, preencha o nome e email.');
        return;
      }
      
      // Validar formato do email
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailRegex.test(email)) {
        alert('Por favor, insira um email válido.');
        return;
      }
      {% endif %}
      
      // Preparar dados da reserva no formato esperado pela página de pagamento
      const totalBar = calcularTotalBar();
      const totalBilhetes = quantidadeBilhetes * precoUnitario;
      const totalGeral = totalBilhetes + totalBar;
      
      const dadosReserva = {
        // Dados da sessão (formato esperado pelo backend)
        filme_id: sessaoData.filme_id,
        cinema_id: sessaoData.cinema_id,
        tipo_id: sessaoData.tipo_id,
        horario_id: sessaoData.horario_id,
        data_sessao: sessaoData.data_sessao,
        
        // Dados dos bilhetes
        lugares: lugaresSelecionados,
        quantidade_bilhetes: quantidadeBilhetes,
        preco_unitario: precoUnitario,
        total_bilhetes: totalBilhetes,
        
        // Dados do bar
        produtos_bar: produtosBar,
        total_bar: totalBar,
        
        // Total geral
        total_geral: totalGeral,
        
        // Dados pessoais
        {% if user_authenticated %}
        nome: '{{ user_name }}',
        email: '{{ user_email }}',
        telefone: '', // Será preenchido se necessário
        {% else %}
        nome: document.getElementById('nome').value.trim(),
        email: document.getElementById('email').value.trim(),
        telefone: document.getElementById('telefone').value.trim(),
        {% endif %}
        
        // Metadados
        tipo_reserva: 'cinema',
        categoria: 'bilhete'
      };
      
      // Debug: mostrar dados que serão enviados
      console.log('=== DADOS DA RESERVA PREPARADOS ===');
      console.log('Dados completos:', dadosReserva);
      console.log('Sessão:', sessaoData);
      console.log('Lugares selecionados:', lugaresSelecionados);
      console.log('Produtos do bar:', produtosBar);
      
      // Validar dados críticos
      if (!dadosReserva.filme_id || !dadosReserva.cinema_id || !dadosReserva.horario_id) {
        console.error('Dados críticos faltando:', {
          filme_id: dadosReserva.filme_id,
          cinema_id: dadosReserva.cinema_id,
          horario_id: dadosReserva.horario_id
        });
        alert('Erro: Dados da sessão incompletos. Tente recarregar a página.');
        return;
      }
      
      // Salvar dados no sessionStorage para a página de pagamento
      try {
        sessionStorage.setItem('dadosReserva', JSON.stringify(dadosReserva));
        console.log('✅ Dados salvos no sessionStorage');
      } catch (error) {
        console.error('❌ Erro ao salvar no sessionStorage:', error);
        alert('Erro ao preparar dados para pagamento. Tente novamente.');
        return;
      }
      
      // Mostrar loading no botão
      const btnFinalizar = document.getElementById('finalizar-reserva');
      const originalText = btnFinalizar.innerHTML;
      btnFinalizar.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processando...';
      btnFinalizar.disabled = true;
      
      // Verificar se os dados foram salvos corretamente
      const dadosVerificacao = sessionStorage.getItem('dadosReserva');
      if (!dadosVerificacao) {
        console.error('❌ Falha ao salvar dados no sessionStorage');
        alert('Erro ao preparar dados. Tente novamente.');
        btnFinalizar.innerHTML = originalText;
        btnFinalizar.disabled = false;
        return;
      }
      
      // Redirecionar para página de pagamento após um pequeno delay
      setTimeout(() => {
        console.log('🔄 Redirecionando para pagamento...');
        console.log('📦 Dados no sessionStorage:', JSON.parse(dadosVerificacao));
        window.location.href = '/reserva/pagamento';
      }, 800);
    }
    
    function calcularTotalBar() {
      let total = 0;
      console.log('Calculando total do bar. Produtos:', produtosBar);
      
      for (const produtoId in produtosBar) {
        const produto = produtosBar[produtoId];
        
        // Buscar preço do produto no DOM
        const precoElement = document.querySelector(`[data-produto-id="${produtoId}"] .produto-preco`);
        if (precoElement) {
          const precoTexto = precoElement.textContent.replace('€', '').replace(',', '.').trim();
          const preco = parseFloat(precoTexto);
          const subtotal = preco * produto.quantidade;
          total += subtotal;
          
          console.log(`Produto ${produtoId}: ${preco}€ x ${produto.quantidade} = ${subtotal}€`);
        } else {
          console.warn(`Elemento de preço não encontrado para produto ${produtoId}`);
        }
      }
      
      console.log('Total do bar calculado:', total);
      return total;
    }



    // Eventos de validação em tempo real
    {% if not user_authenticated %}
    document.addEventListener('DOMContentLoaded', function() {
      const inputs = ['nome', 'email', 'telefone'];
      inputs.forEach(inputId => {
        const input = document.getElementById(inputId);
        if (input) {
          input.addEventListener('input', atualizarResumo);
          input.addEventListener('blur', atualizarResumo);
        }
      });
    });
    {% endif %}
  </script>
</body>
</html>