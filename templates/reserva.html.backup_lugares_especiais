  <script>
    // Variáveis globais
    let quantidadeBilhetes = 0;
    let lugaresSelecionados = [];
    let produtosBar = {};
    let precoUnitario = {% if horario and horario.preco %}{{ horario.preco }}{% else %}8.50{% endif %};
    let ultimaAreaSelecionada = null; // Para evitar repetir a mesma área
    
    // FUNÇÃO PARA CALCULAR LAYOUT DINÂMICO DA SALA
    function calcularLayoutSala(capacidade) {
      let layout = {};
      
      if (capacidade <= 100) {
        // SALA PEQUENA (até 100 lugares)
        layout = {
          filas: ['A', 'B', 'C', 'D', 'E', 'F', 'G'],
          lugaresporFila: 14, // 3 + 4 + corredor + 4 + 3 = 14
          distribuicao: { lateral: 3, centro: 4 }
        };
      } else if (capacidade <= 150) {
        // SALA MÉDIA (101-150 lugares)
        layout = {
          filas: ['A', 'B', 'C', 'D', 'E', 'F', 'G', 'H'],
          lugaresporFila: 18, // 4 + 5 + corredor + 5 + 4 = 18
          distribuicao: { lateral: 4, centro: 5 }
        };
      } else if (capacidade <= 250) {
        // SALA GRANDE (151-250 lugares)
        layout = {
          filas: ['A', 'B', 'C', 'D', 'E', 'F', 'G', 'H', 'I', 'J'],
          lugaresporFila: 22, // 5 + 6 + corredor + 6 + 5 = 22
          distribuicao: { lateral: 5, centro: 6 }
        };
      } else {
        // SALA PREMIUM (251+ lugares)
        layout = {
          filas: ['A', 'B', 'C', 'D', 'E', 'F', 'G', 'H', 'I', 'J', 'K', 'L'],
          lugaresporFila: 28, // 6 + 8 + corredor + 8 + 6 = 28
          distribuicao: { lateral: 6, centro: 8 }
        };
      }
      
      return layout;
    }
    
    // FUNÇÃO PARA GERAR LUGARES ESPECIAIS BASEADA NA BASE DE DADOS
    function gerarLugaresEspeciaisBD(filas, layout) {
      const numFilas = filas.length;
      const lugaresporFila = layout.lugaresporFila;
      const lateral = layout.distribuicao.lateral;
      const centro = layout.distribuicao.centro;
      
      // Quantidades da base de dados
      const qtdAcessiveis = layout.lugaresEspeciais.acessiveis;
      const qtdCasal = layout.lugaresEspeciais.casal;
      const qtdPremium = layout.lugaresEspeciais.premium;
      const tipoSala = layout.lugaresEspeciais.tipoSala;
      
      // Só aplicar em salas normais
      if (tipoSala !== 'Normal') {
        return { acessiveis: [], casal: [], premium: [] };
      }
      
      // Calcular posições estratégicas
      const filaMeio = Math.floor(numFilas / 2);
      const filaFinal = numFilas - 1;
      
      // LUGARES ACESSÍVEIS (sempre nas laterais, em pares)
      const acessiveis = [];
      for (let i = 0; i < qtdAcessiveis && i < 8; i += 2) {
        const fila = filas[filaMeio + Math.floor(i / 4)];
        if (i < 4) {
          // Lado esquerdo
          acessiveis.push(`${fila}1`, `${fila}2`);
        } else {
          // Lado direito
          acessiveis.push(`${fila}${lugaresporFila-1}`, `${fila}${lugaresporFila}`);
        }
      }
      
      // LUGARES DE CASAL (centro das melhores filas, em pares)
      const casal = [];
      const centroEsq = lateral + Math.floor(centro / 2);
      const centroDir = lateral + centro + Math.floor(centro / 2);
      
      for (let i = 0; i < qtdCasal && i < 8; i += 2) {
        const filaIndex = filaMeio - 1 + Math.floor(i / 4);
        const fila = filas[filaIndex];
        if (i < 4) {
          // Centro esquerdo
          casal.push(`${fila}${centroEsq}`, `${fila}${centroEsq + 1}`);
        } else {
          // Centro direito
          casal.push(`${fila}${centroDir}`, `${fila}${centroDir + 1}`);
        }
      }
      
      // LUGARES PREMIUM (melhores posições centrais)
      const premium = [];
      for (let i = 0; i < qtdPremium && i < 8; i += 2) {
        const filaIndex = filaMeio - 2 + Math.floor(i / 4);
        const fila = filas[filaIndex];
        const posicao = lateral + centro / 2 + (i % 4);
        premium.push(`${fila}${posicao}`, `${fila}${posicao + 1}`);
      }
      
      return { acessiveis, casal, premium };
    }
    
    // FUNÇÃO ORIGINAL PARA COMPATIBILIDADE (DEPRECATED)
    function gerarLugaresEspeciais(filas, layout) {
      const numFilas = filas.length;
      const lugaresporFila = layout.lugaresporFila;
      const lateral = layout.distribuicao.lateral;
      const centro = layout.distribuicao.centro;
      
      // Calcular posições centrais
      const centroEsq = lateral + Math.floor(centro / 2);
      const centroDir = lateral + centro + Math.floor(centro / 2);
      
      // Filas do meio (melhores para VIP)
      const filaMeio1 = Math.floor(numFilas * 0.4); // ~40% das filas
      const filaMeio2 = Math.floor(numFilas * 0.5); // ~50% das filas
      const filaMeio3 = Math.floor(numFilas * 0.6); // ~60% das filas
      
      return {
        // Lugares acessíveis (sempre em pares nas laterais)
        acessiveis: [
          `${filas[filaMeio2]}1`, `${filas[filaMeio2]}2`, // Par esquerdo meio
          `${filas[filaMeio2]}${lugaresporFila-1}`, `${filas[filaMeio2]}${lugaresporFila}`, // Par direito meio
          `${filas[numFilas-2]}1`, `${filas[numFilas-2]}2`, // Par esquerdo traseiro
          `${filas[numFilas-2]}${lugaresporFila-1}`, `${filas[numFilas-2]}${lugaresporFila}` // Par direito traseiro
        ],
        
        // Lugares VIP (centro das melhores filas)
        vip: [
          `${filas[filaMeio1]}${centroEsq}`, `${filas[filaMeio1]}${centroEsq+1}`, `${filas[filaMeio1]}${centroDir}`, `${filas[filaMeio1]}${centroDir+1}`,
          `${filas[filaMeio2]}${centroEsq}`, `${filas[filaMeio2]}${centroEsq+1}`, `${filas[filaMeio2]}${centroDir}`, `${filas[filaMeio2]}${centroDir+1}`,
          `${filas[filaMeio3]}${centroEsq}`, `${filas[filaMeio3]}${centroEsq+1}`, `${filas[filaMeio3]}${centroDir}`, `${filas[filaMeio3]}${centroDir+1}`
        ],
        
        // Lugares Premium (boas posições centrais)
        premium: [
          `${filas[filaMeio1-1]}${centroEsq-1}`, `${filas[filaMeio1-1]}${centroEsq}`, `${filas[filaMeio1-1]}${centroDir}`, `${filas[filaMeio1-1]}${centroDir+1}`,
          `${filas[filaMeio1]}${centroEsq-1}`, `${filas[filaMeio1]}${centroEsq+2}`, `${filas[filaMeio1]}${centroDir-1}`, `${filas[filaMeio1]}${centroDir+2}`,
          `${filas[filaMeio2]}${centroEsq-1}`, `${filas[filaMeio2]}${centroEsq+2}`, `${filas[filaMeio2]}${centroDir-1}`, `${filas[filaMeio2]}${centroDir+2}`,
          `${filas[filaMeio3]}${centroEsq-1}`, `${filas[filaMeio3]}${centroEsq}`, `${filas[filaMeio3]}${centroDir}`, `${filas[filaMeio3]}${centroDir+1}`
        ],
        
        // Lugares Casal (SOLUÇÃO DEFINITIVA - sempre duplas consecutivas)
        casal: (() => {
          const lugaresCasal = [];
          const filasCasal = filaMeio2; // Usar fila do meio
          
          // DEFINIÇÃO FIXA E SIMPLES - sempre duplas consecutivas
          // Posições centralizadas mais à direita conforme solicitado
          if (lugaresporFila >= 28) {
            // Sala grande (28 lugares) - 6 duplas bem espaçadas
            lugaresCasal.push(
              `${filas[filasCasal]}10`, `${filas[filasCasal]}11`,  // Dupla 1
              `${filas[filasCasal]}13`, `${filas[filasCasal]}14`,  // Dupla 2
              `${filas[filasCasal]}16`, `${filas[filasCasal]}17`,  // Dupla 3
              `${filas[filasCasal]}19`, `${filas[filasCasal]}20`,  // Dupla 4
              `${filas[filasCasal]}22`, `${filas[filasCasal]}23`,  // Dupla 5
              `${filas[filasCasal]}25`, `${filas[filasCasal]}26`   // Dupla 6
            );
          } else if (lugaresporFila >= 22) {
            // Sala média-grande (22 lugares) - 5 duplas
            lugaresCasal.push(
              `${filas[filasCasal]}7`, `${filas[filasCasal]}8`,    // Dupla 1
              `${filas[filasCasal]}10`, `${filas[filasCasal]}11`,  // Dupla 2
              `${filas[filasCasal]}13`, `${filas[filasCasal]}14`,  // Dupla 3
              `${filas[filasCasal]}16`, `${filas[filasCasal]}17`,  // Dupla 4
              `${filas[filasCasal]}19`, `${filas[filasCasal]}20`   // Dupla 5
            );
          } else if (lugaresporFila >= 18) {
            // Sala média (18 lugares) - 4 duplas
            lugaresCasal.push(
              `${filas[filasCasal]}6`, `${filas[filasCasal]}7`,    // Dupla 1
              `${filas[filasCasal]}9`, `${filas[filasCasal]}10`,   // Dupla 2
              `${filas[filasCasal]}12`, `${filas[filasCasal]}13`,  // Dupla 3
              `${filas[filasCasal]}15`, `${filas[filasCasal]}16`   // Dupla 4
            );
          } else {
            // Sala pequena (14 lugares) - 3 duplas
            lugaresCasal.push(
              `${filas[filasCasal]}5`, `${filas[filasCasal]}6`,    // Dupla 1
              `${filas[filasCasal]}8`, `${filas[filasCasal]}9`,    // Dupla 2
              `${filas[filasCasal]}11`, `${filas[filasCasal]}12`   // Dupla 3  
            );
          }
          
          return lugaresCasal;
        })()
      };
    }
    
    // Dados da sessão
    const sessaoData = {
      filme_id: {% if filme and filme.id %}{{ filme.id }}{% else %}null{% endif %},
      cinema_id: {% if cinema and cinema.id %}{{ cinema.id }}{% else %}null{% endif %},
      tipo_id: {% if tipo_sessao and tipo_sessao.id %}{{ tipo_sessao.id }}{% else %}null{% endif %},
      sala_id: {% if sala and sala.id %}{{ sala.id }}{% else %}null{% endif %},
      horario_id: {% if horario and horario.id %}{{ horario.id }}{% else %}null{% endif %},
      data_sessao: '{% if data_sessao %}{{ data_sessao }}{% else %}{% endif %}',
      preco_unitario: precoUnitario
    };
    
    console.log('Dados da sessão inicializados:', sessaoData);

    // Sidebar
    const resumoBilhetes = document.getElementById('resumo-bilhetes');
    const resumoLugaresSidebar = document.getElementById('resumo-lugares-sidebar');
    const resumoBarSidebar = document.getElementById('resumo-bar-sidebar');
    const resumoTotalSidebar = document.getElementById('resumo-total-sidebar');

    // Elementos do DOM
    const passos = document.querySelectorAll('.form-step');
    const btnsBilhete = document.querySelectorAll('.btn-bilhete');
    const quantidadeInput = document.getElementById('quantidade-bilhetes');
    const btnMenos = document.getElementById('btn-menos-bilhetes');
    const btnMais = document.getElementById('btn-mais-bilhetes');
    const btnContinuarLugares = document.getElementById('continuar-lugares');

    // Inicialização
    document.addEventListener('DOMContentLoaded', function() {
      inicializarEventos();
      atualizarResumo();
    });

    function inicializarEventos() {
      // Eventos dos bilhetes
      btnsBilhete.forEach(btn => {
        btn.addEventListener('click', () => selecionarQuantidade(parseInt(btn.dataset.qtd)));
      });

      btnMenos.addEventListener('click', () => {
        if (quantidadeInput.value > 1) {
          quantidadeInput.value = parseInt(quantidadeInput.value) - 1;
          selecionarQuantidade(parseInt(quantidadeInput.value));
        }
      });

      btnMais.addEventListener('click', () => {
