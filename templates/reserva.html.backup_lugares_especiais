<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reserva de Bilhetes | CineVibe</title>

  <!-- Fontes -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700;900&display=swap" rel="stylesheet">
  
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <!-- CSS -->
  <link rel="stylesheet" href="{{ url_for('static', filename='css/style.css') }}">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/reserva.css') }}">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/corredor-vermelho.css') }}">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/produtos-bar-premium.css') }}">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/resumo-finalizacao-premium.css') }}">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/modal-lugares-premium.css') }}">

</head>
<body>
  <!-- Header -->
  <header>
    <div class="top-nav">
      <div class="nav-left">
        <img src="{{ url_for('static', filename='imgs/Logo/logo8 sem fundo.png') }}" alt="logo CineVibe" class="logo">
      </div>

      <div class="nav-right">
        <div class="search-container">
          <input type="text" placeholder="Procurar Filmes...">
          <img src="{{ url_for('static', filename='imgs/icons/OIP-removebg-preview (4).png') }}" alt="search_icon" class="search_icon">
        </div>

        <div class="user-icon">
    {% if logged_in %}
        <a href="{{ url_for('perfil') }}">
            <img src="{{ url_for('static', filename=avatar) }}" class="user-pic" alt="Perfil">
        </a>
    {% else %}
        <a href="{{ url_for('login') }}">
            <img src="{{ url_for('static', filename='imgs/icons/user_icon34-removebg-preview.png') }}" alt="Login">
        </a>
    {% endif %}
</div>
      </div>
    </div>
  </header>

  <!-- Navegação -->
  <nav class="nav-center">
    <a href="{{ url_for('home') }}">Home</a>
    <a href="{{ url_for('filmes') }}">Filmes</a>
    <a href="{{ url_for('cinemas') }}">Cinemas</a>
    <a href="{{ url_for('cine_acessivel') }}">CineAcessível</a>
    <a href="{{ url_for('bar') }}">Bar</a>
    <a href="{{ url_for('beneficios') }}">Benefícios</a>
    <a href="{{ url_for('sessao') }}">Sessão Só Para Ti</a>
    <a href="{{ url_for('contactos') }}">Contactos</a>
  </nav>

  <div class="page-wrapper">
    <!-- Main Content -->
    <main class="reserva-main-container">
      <div class="reserva-layout">
        
        <!-- Sidebar (oculta inicialmente) -->
        <div class="reserva-left">
          <div class="info-panel">
            <div class="filme-info">
              <h3>{{ filme.titulo }}</h3>
              <div class="sessao-info">
                <h4>Sessão</h4>
                <div class="sessao-meta">
                  <div class="meta-row">
                    <span class="meta-label">Data:</span>
                    <span class="meta-value">{{ data_sessao }}</span>
                  </div>
                  <div class="meta-row">
                    <span class="meta-label">Hora:</span>
                    <span class="meta-value">{{ horario.hora_str if horario else 'N/A' }}</span>
                  </div>
                  <div class="meta-row">
                    <span class="meta-label">Cinema:</span>
                    <span class="meta-value">{{ cinema.nome }}</span>
                  </div>
                  <div class="meta-row">
                    <span class="meta-label">Sala:</span>
                    <span class="meta-value">{{ sala.nome_sala if sala else 'N/A' }}</span>
                  </div>
                </div>
              </div>
              
              <div class="resumo-reserva">
                <h4>Resumo</h4>
                <div class="resumo-content">
                  <div class="resumo-item">
                    <span class="resumo-label">Bilhetes:</span>
                    <span class="resumo-value" id="resumo-bilhetes">0</span>
                  </div>
                  <div class="resumo-item">
                    <span class="resumo-label">Lugares:</span>
                    <span class="resumo-value" id="resumo-lugares-sidebar">-</span>
                  </div>
                  <div class="resumo-item">
                    <span class="resumo-label">Bar:</span>
                    <span class="resumo-value" id="resumo-bar-sidebar">0.00€</span>
                  </div>
                  <div class="resumo-item total">
                    <span class="resumo-label">Total:</span>
                    <span class="resumo-value" id="resumo-total-sidebar">0.00€</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Main Content Area -->
        <div class="reserva-right">
          <div class="reserva-form-container">

            <!-- PASSO 1: QUANTIDADE DE BILHETES -->
            <div id="passo-bilhetes" class="form-step active">
              <div class="step-header">
                <h2>1. Quantos bilhetes?</h2>
                <p>Selecione a quantidade de bilhetes desejada</p>
              </div>
              
              <div class="bilhetes-grid">
                <button class="btn-bilhete" data-qtd="1">
                  <span class="bilhete-numero">1</span>
                  <span class="bilhete-label">Bilhete</span>
                </button>
                <button class="btn-bilhete" data-qtd="2">
                  <span class="bilhete-numero">2</span>
                  <span class="bilhete-label">Bilhetes</span>
                </button>
                <button class="btn-bilhete" data-qtd="3">
                  <span class="bilhete-numero">3</span>
                  <span class="bilhete-label">Bilhetes</span>
                </button>
                <button class="btn-bilhete" data-qtd="4">
                  <span class="bilhete-numero">4</span>
                  <span class="bilhete-label">Bilhetes</span>
                </button>
                <button class="btn-bilhete" data-qtd="5">
                  <span class="bilhete-numero">5</span>
                  <span class="bilhete-label">Bilhetes</span>
                </button>
                <button class="btn-bilhete" data-qtd="6">
                  <span class="bilhete-numero">6</span>
                  <span class="bilhete-label">Bilhetes</span>
                </button>
              </div>

              <!-- Quantidade Custom -->
              <div class="quantidade-custom-wrapper">
                <p class="quantidade-label">Ou escolha outra quantidade</p>
                <div class="quantidade-controls">
                  <button type="button" id="btn-menos-bilhetes" class="btn-qty-mini">-</button>
                  <input type="number" id="quantidade-bilhetes" class="input-qty-mini" min="1" max="50" value="1" />
                  <button type="button" id="btn-mais-bilhetes" class="btn-qty-mini">+</button>
                </div>
                <p class="quantidade-hint">Selecione de 1 a 50 bilhetes</p>
              </div>

              <!-- Botão Continuar -->
              <div class="step-actions-wrapper">
                <button id="continuar-lugares" class="btn-continuar-lugares" disabled>
                  Continuar para Lugares
                  <span class="btn-arrow"><i class="fas fa-arrow-right"></i></span>
                </button>
              </div>
            </div>

            <!-- PASSO 2: SELEÇÃO DE LUGARES -->
            <div id="passo-lugares" class="form-step">
              <div class="step-header">
                <h2>2. Escolha os lugares</h2>
                <p>Selecione <span id="lugares-necessarios">0</span> lugares na sala</p>
              </div>

              <div class="sala-container">
                <div class="tela-cinema">
                  <span class="tela-label">Ecrã</span>
                </div>
                
                <div class="sala-dinamica" id="sala-lugares">
                  <!-- Lugares serão gerados dinamicamente -->
                </div>
              </div>



              <div class="lugares-info">
                <div class="lugares-instrucoes">
                  <p><i class="fas fa-hand-pointer"></i> Clique nos lugares desejados na planta acima</p>
                </div>
                
                <div class="lugares-selecionados">
                  <strong>Lugares selecionados:</strong>
                  <span id="lugares-display">Nenhum</span>
                </div>
                
                <button id="btn-info-lugares" class="btn-info-lugares" type="button">
                  <i class="fas fa-info-circle"></i> Informações dos Lugares
                </button>
              </div>

              <!-- Modal de Informações Ultra Premium -->
              <div id="modal-info" class="modal-lugares-overlay modal-hidden">
                <div class="modal-lugares-container">
                  <div class="modal-lugares-header">
                    <div class="modal-icon">
                      <i class="fas fa-info-circle"></i>
                    </div>
                    <h3>Informações dos Lugares</h3>
                    <button class="modal-close-btn" id="modal-close">
                      <i class="fas fa-times"></i>
                    </button>
                  </div>
                  
                  <div class="modal-lugares-content">
                    <!-- Tipos de Lugares -->
                    <div class="tipos-lugares-section">
                      <h4><i class="fas fa-couch"></i> Tipos de Lugares</h4>
                      <div class="tipos-grid">
                        <div class="tipo-item">
                          <div class="tipo-visual disponivel-visual"></div>
                          <div class="tipo-info">
                            <span class="tipo-nome">Disponível</span>
                            <span class="tipo-desc">Lugares livres para seleção</span>
                          </div>
                        </div>
                        
                        <div class="tipo-item">
                          <div class="tipo-visual selecionado-visual"></div>
                          <div class="tipo-info">
                            <span class="tipo-nome">Selecionado</span>
                            <span class="tipo-desc">Lugares escolhidos por si</span>
                          </div>
                        </div>
                        
                        <div class="tipo-item">
                          <div class="tipo-visual ocupado-visual">✕</div>
                          <div class="tipo-info">
                            <span class="tipo-nome">Ocupado</span>
                            <span class="tipo-desc">Já reservado por outros</span>
                          </div>
                        </div>
                        
                        <div class="tipo-item">
                          <div class="tipo-visual acessivel-visual">
                            <img src="{{ url_for('static', filename='imgs/cadeira_rodas_icon-removebg-preview.png') }}" 
                                 alt="Acessível" class="acessivel-icon">
                          </div>
                          <div class="tipo-info">
                            <span class="tipo-nome">Acessível</span>
                            <span class="tipo-desc">Para pessoas com mobilidade reduzida</span>
                          </div>
                        </div>
                        
                        <div class="tipo-item">
                          <div class="tipo-visual casal-visual">
                            <img src="{{ url_for('static', filename='imgs/icons/ChatGPT_Image_Dec_15__2025__05_05_22_PM-removebg-preview.png') }}" 
                                 alt="Casal" class="casal-icon">
                          </div>
                          <div class="tipo-info">
                            <span class="tipo-nome">Lugares de Casal</span>
                            <span class="tipo-desc">Lugares especiais para casais</span>
                          </div>
                        </div>
                      </div>
                    </div>
                    
                    <!-- Informações Importantes -->
                    <div class="info-importantes-section">
                      <h4><i class="fas fa-star"></i> Informações Importantes</h4>
                      <div class="info-cards">
                        <div class="info-card">
                          <div class="info-card-icon">
                            <img src="{{ url_for('static', filename='imgs/cadeira_rodas_icon-removebg-preview.png') }}" 
                                 alt="Acessibilidade" class="info-icon">
                          </div>
                          <div class="info-card-text">
                            <span class="info-title">Acessibilidade</span>
                            <span class="info-desc">Lugares estratégicos para fácil acesso</span>
                          </div>
                        </div>
                        
                        <div class="info-card">
                          <div class="info-card-icon">
                            <i class="fas fa-eye"></i>
                          </div>
                          <div class="info-card-text">
                            <span class="info-title">Visibilidade</span>
                            <span class="info-desc">Excelente vista do ecrã em todos os lugares</span>
                          </div>
                        </div>
                        
                        <div class="info-card">
                          <div class="info-card-icon">
                            <i class="fas fa-volume-up"></i>
                          </div>
                          <div class="info-card-text">
                            <span class="info-title">Som Surround</span>
                            <span class="info-desc">Sistema de áudio premium em toda a sala</span>
                          </div>
                        </div>
                        
                        <div class="info-card">
                          <div class="info-card-icon">
                            <i class="fas fa-snowflake"></i>
                          </div>
                          <div class="info-card-text">
                            <span class="info-title">Climatização</span>
                            <span class="info-desc">Temperatura controlada para máximo conforto</span>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                  
                  <div class="modal-lugares-footer">
                    <button class="btn-entendido" id="btn-modal-close">
                      <i class="fas fa-check"></i>
                      Entendido
                    </button>
                  </div>
                </div>
              </div>

              <div class="step-actions">
                <button id="voltar-bilhetes" class="btn-secondary"><i class="fas fa-arrow-left"></i> Voltar</button>
                <button id="continuar-bar" class="btn-primary" disabled>
                  Continuar <i class="fas fa-arrow-right"></i>
                </button>
              </div>
            </div>

            <!-- PASSO 3: BAR (OPCIONAL) -->
            <div id="passo-bar" class="form-step">
              <div class="step-header">
                <h2>3. Bar (Opcional)</h2>
                <p>Adicione produtos do bar à sua reserva</p>
              </div>

              <div class="bar-content">
                <div class="bar-categorias">
                  <button class="categoria-btn active" data-categoria="menus">
                    <i class="fas fa-utensils"></i>Menus
                  </button>
                  <button class="categoria-btn" data-categoria="bebidas">
                    <i class="fas fa-glass-cheers"></i>Bebidas
                  </button>
                  <button class="categoria-btn" data-categoria="snacks">
                    <i class="fas fa-cookie-bite"></i>Snacks
                  </button>
                </div>



                <div class="produtos-container">
                  <!-- Menus -->
                  <div class="categoria-produtos active" id="categoria-menus">
                    {% for menu in menus_bar %}
                    <div class="produto-card" data-produto-id="menu-{{ menu.id }}">
                      <div class="produto-imagem">
                        <img src="{{ menu.imagem_url if menu.imagem_url else url_for('static', filename='imgs/bar/menu-default.svg') }}" 
                             alt="{{ menu.nome }}" 
                             class="produto-img"
                             loading="eager"
                             decoding="async">
                        <div class="produto-overlay">
                          <i class="fas fa-utensils"></i>
                        </div>
                      </div>
                      <div class="produto-info">
                        <h4>{{ menu.nome }}</h4>
                        <p>{{ menu.descricao }}</p>
                        <span class="produto-preco">{{ "%.2f"|format(menu.preco_total) }}€</span>
                      </div>
                      <div class="produto-controls">
                        <button class="btn-menos" data-id="menu-{{ menu.id }}" data-tipo="menu" disabled>-</button>
                        <span class="quantidade" data-id="menu-{{ menu.id }}">0</span>
                        <button class="btn-mais" data-id="menu-{{ menu.id }}" data-tipo="menu">+</button>
                      </div>
                    </div>
                    {% endfor %}
                  </div>

                  <!-- Produtos -->
                  <div class="categoria-produtos" id="categoria-bebidas">
                    {% for produto in produtos_bar if produto.tipo.lower() in ['bebida', 'drink'] %}
                    <div class="produto-card" data-produto-id="produto-{{ produto.id }}">
                      <div class="produto-imagem">
                        <img src="{{ produto.imagem if produto.imagem else url_for('static', filename='imgs/bar/bebida-default.svg') }}" 
                             alt="{{ produto.nome }}" 
                             class="produto-img"
                             loading="eager"
                             decoding="async">
                        <div class="produto-overlay">
                          <i class="fas fa-glass-cheers"></i>
                        </div>
                      </div>
                      <div class="produto-info">
                        <h4>{{ produto.nome }}</h4>
                        <p>{{ produto.descricao if produto.descricao else 'Deliciosa bebida para acompanhar o filme' }}</p>
                        <span class="produto-preco">{{ "%.2f"|format(produto.preco) }}€</span>
                      </div>
                      <div class="produto-controls">
                        <button class="btn-menos" data-id="produto-{{ produto.id }}" data-tipo="produto" disabled>-</button>
                        <span class="quantidade" data-id="produto-{{ produto.id }}">0</span>
                        <button class="btn-mais" data-id="produto-{{ produto.id }}" data-tipo="produto">+</button>
                      </div>
                    </div>
                    {% endfor %}
                  </div>

                  <div class="categoria-produtos" id="categoria-snacks">
                    {% for produto in produtos_bar if produto.tipo.lower() in ['snack', 'lanche'] %}
                    <div class="produto-card" data-produto-id="produto-{{ produto.id }}">
                      <div class="produto-imagem">
                        <img src="{{ produto.imagem if produto.imagem else url_for('static', filename='imgs/bar/snack-default.svg') }}" 
                             alt="{{ produto.nome }}" 
                             class="produto-img"
                             loading="eager"
                             decoding="async">
                        <div class="produto-overlay">
                          <i class="fas fa-cookie-bite"></i>
                        </div>
                      </div>
                      <div class="produto-info">
                        <h4>{{ produto.nome }}</h4>
                        <p>{{ produto.descricao if produto.descricao else 'Delicioso snack para acompanhar o filme' }}</p>
                        <span class="produto-preco">{{ "%.2f"|format(produto.preco) }}€</span>
                      </div>
                      <div class="produto-controls">
                        <button class="btn-menos" data-id="produto-{{ produto.id }}" data-tipo="produto" disabled>-</button>
                        <span class="quantidade" data-id="produto-{{ produto.id }}">0</span>
                        <button class="btn-mais" data-id="produto-{{ produto.id }}" data-tipo="produto">+</button>
                      </div>
                    </div>
                    {% endfor %}
                  </div>
                </div>
              </div>

              <div class="step-actions">
                <button id="voltar-lugares-bar" class="btn-secondary"><i class="fas fa-arrow-left"></i> Voltar aos Lugares</button>
                <button id="pular-bar" class="btn-skip">Pular Bar</button>
                <button id="continuar-confirmacao-bar" class="btn-primary">
                  Continuar <i class="fas fa-arrow-right"></i>
                </button>
              </div>
            </div>

            <!-- PASSO 4: CONFIRMAÇÃO -->
            <div id="passo-confirmacao" class="form-step">
              <div class="step-header">
                <h2>4. Resumo e Finalização</h2>
                <p>Confirme os detalhes e complete a sua reserva</p>
              </div>

              <!-- Layout de Duas Colunas -->
              <div class="resumo-layout">
                
                <!-- Coluna Esquerda: Resumo -->
                <div class="resumo-coluna">
                  <div class="resumo-card-unico">
                    <div class="title-with-icon">
                      <i class="fas fa-receipt"></i>
                    </div>
                    <h3>Resumo da Reserva</h3>
                  </div>

                  <!-- Informações da Sessão -->
                  <div class="resumo-section">
                    <h4><i class="fas fa-video"></i> Sessão de Cinema</h4>
                    <div class="resumo-details">
                      <div class="detail-row">
                        <span class="detail-label"><i class="fas fa-film"></i> Filme:</span>
                        <span class="detail-value" id="resumo-filme-titulo">{{ filme.titulo }}</span>
                      </div>
                      <div class="detail-row">
                        <span class="detail-label"><i class="fas fa-clock"></i> Data & Hora:</span>
                        <span class="detail-value" id="resumo-sessao-data">
                          {% if data_sessao %}{{ data_sessao }}{% else %}Data não definida{% endif %} às 
                          {% if horario and horario.hora_str %}{{ horario.hora_str }}{% else %}Hora não definida{% endif %}
                        </span>
                      </div>
                      <div class="detail-row">
                        <span class="detail-label"><i class="fas fa-map-marker-alt"></i> Cinema:</span>
                        <span class="detail-value" id="resumo-cinema">{{ cinema.nome }}</span>
                      </div>
                      <div class="detail-row">
                        <span class="detail-label"><i class="fas fa-couch"></i> Sala:</span>
                        <span class="detail-value" id="resumo-sala">{{ sala.nome_sala if sala and sala.nome_sala else 'Não definida' }}</span>
                      </div>
                    </div>
                  </div>

                  <!-- Informações dos Bilhetes -->
                  <div class="resumo-section">
                    <h4><i class="fas fa-tickets-alt"></i> Bilhetes</h4>
                    <div class="resumo-details">
                      <div class="detail-row">
                        <span class="detail-label">Quantidade:</span>
                        <span class="detail-value"><span id="resumo-bilhetes-qtd">0</span> bilhete(s)</span>
                      </div>
                      <div class="detail-row">
                        <span class="detail-label">Preço unitário:</span>
                        <span class="detail-value" id="resumo-preco-unitario">8.50€</span>
                      </div>
                      <div class="detail-row">
                        <span class="detail-label">Lugares:</span>
                        <span class="detail-value" id="resumo-lugares-lista">Nenhum selecionado</span>
                      </div>
                      <div class="detail-row subtotal">
                        <span class="detail-label">Subtotal Bilhetes:</span>
                        <span class="detail-value" id="resumo-bilhetes-total">0.00€</span>
                      </div>
                    </div>
                  </div>

                  <!-- Informações do Bar -->
                  <div class="resumo-section resumo-section-hidden" id="resumo-bar-section">
                    <h4><i class="fas fa-utensils"></i> Produtos do Bar</h4>
                    <div class="resumo-details">
                      <div id="resumo-bar-produtos">
                        <!-- Produtos serão adicionados dinamicamente -->
                      </div>
                      <div class="detail-row subtotal">
                        <span class="detail-label">Subtotal Bar:</span>
                        <span class="detail-value" id="resumo-bar-total">0.00€</span>
                      </div>
                    </div>
                  </div>

                  <!-- Total Final -->
                  <div class="resumo-item-moderno total-especial">
                    <span class="resumo-label-moderno">Total a Pagar</span>
                    <span class="resumo-valor-moderno" id="resumo-total-final">0.00€</span>
                  </div>
                </div>

                <!-- Coluna Direita: Dados Pessoais -->
                <div class="dados-coluna">
                  <div class="dados-card">
                    <div class="title-with-icon">
                      <i class="fas fa-user"></i>
                    </div>
                    <h3>Dados Pessoais</h3>
                  </div>

                  {% if user_authenticated %}
                    <!-- Usuário Logado -->
                    <div class="user-info-container">
                      <div class="user-info-content">
                        <i class="fas fa-check-circle"></i>
                        <div>
                          <p class="logged-name">Autenticado como <strong>{{ user_name }}</strong></p>
                          <p class="logged-email">Confirmação será enviada para: <strong>{{ user_email }}</strong></p>
                        </div>
                      </div>
                    </div>
                  {% else %}
                    <!-- Formulário para Não Logados -->
                    <div class="dados-form">
