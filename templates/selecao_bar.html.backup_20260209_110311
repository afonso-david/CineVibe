<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Seleção do Bar | CineVibe</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/selecao_lugares.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/filme_detalhe.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/selecao_bar.css') }}">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Montserrat:wght@400;600;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
    <div class="page-wrapper">
        <!-- Header -->
        <header>
            <div class="top-nav">
                <div class="nav-left">
                    <img src="{{ url_for('static', filename='imgs/Logo/logo8 sem fundo.png') }}" alt="logo CineVibe" class="logo">
                </div>
                <div class="nav-right">
                    <div class="user-icon">
                        {% if user_authenticated %}
                            <a href="{{ url_for('perfil') }}">
                                <img src="{{ url_for('static', filename=user_avatar) }}" class="user-pic" alt="Perfil">
                            </a>
                        {% else %}
                            <a href="{{ url_for('login') }}">
                                <img src="{{ url_for('static', filename='imgs/icons/user_icon34-removebg-preview.png') }}" alt="Login">
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </header>

        <!-- Navegação -->
        <nav class="nav-center">
            <a href="{{ url_for('home') }}">Home</a>
            <a href="{{ url_for('filmes') }}">Filmes</a>
            <a href="{{ url_for('cinemas') }}">Cinemas</a>
            <a href="{{ url_for('cine_acessivel') }}">CineAcessível</a>
            <a href="{{ url_for('bar') }}">Bar</a>
            <a href="{{ url_for('beneficios') }}">Benefícios</a>
            <a href="{{ url_for('sessao') }}">Sessão Só Para Ti</a>
            <a href="{{ url_for('contactos') }}">Contactos</a>
        </nav>

        <!-- Main Content -->
        <main style="padding: 2rem 0; background: #0D1B2A; min-height: 100vh;">
            <div class="container" style="max-width: 1200px; margin: 0 auto; padding: 0 20px;">
                
                <!-- Movie Info Card (igual a selecao_lugares) -->
                <div class="movie-info-card">
                    <div class="movie-info-content">
                        {% set poster_path = filme.poster_url.replace('imgs/filmes/', '') if filme.poster_url and 'imgs/filmes/' in filme.poster_url else filme.poster_url %}
                        <img src="{{ url_for('static', filename='imgs/filmes/' + (poster_path if poster_path and not poster_path.startswith('http') else 'placeholder.svg')) }}" 
                             alt="{{ filme.titulo }}" 
                             class="movie-poster"
                             onerror="this.src='{{ url_for('static', filename='imgs/filmes/placeholder.svg') }}'">
                        <div class="movie-details">
                            <h1 class="movie-title">{{ filme.titulo }}</h1>
                            <div class="movie-info-item">
                                <i class="fas fa-map-marker-alt"></i>
                                <span class="cinema-name">{{ cinema.nome }}</span>
                            </div>
                            <div class="movie-info-item">
                                <i class="fas fa-film"></i>
                                <span class="session-type">{{ tipo_sessao.nome }}</span>
                            </div>
                            <div class="movie-info-item">
                                <i class="fas fa-clock"></i>
                                <span class="session-time">{{ horario.hora_str }} - {{ data_sessao }}</span>
                            </div>
                            <div class="movie-info-item">
                                <i class="fas fa-chair"></i>
                                <span class="seats-info">Lugares: {{ lugares_selecionados|join(', ') }}</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Bar Selection -->
                <div class="bar-selection">
                    <div class="section-header">
                        <i class="fas fa-utensils"></i>
                        <h3>Deseja algo do nosso Bar?</h3>
                        <p>Aproveite e peça os seus snacks favoritos para desfrutar durante o filme!</p>
                    </div>

                    <!-- Skip Option -->
                    <div class="skip-option">
                        <a href="{{ url_for('selecao_toppings', filme_id=filme_id, cinema_id=cinema_id, tipo_sessao_id=tipo_sessao_id, horario_id=horario_id, data_sessao=data_sessao, lugares=lugares_selecionados|join(','), quantidade=lugares_selecionados|length, produtos_bar='[]') }}" class="skip-btn">
                            <i class="fas fa-forward"></i>
                            Não, obrigado. Continuar sem produtos do bar
                        </a>
                    </div>

                    <!-- Menu Categories -->
                    <div class="menu-categories">
                        <div class="category-tabs">
                            <button class="tab-btn active" data-category="menus">
                                <i class="fas fa-box"></i>
                                Menus
                            </button>
                            <button class="tab-btn" data-category="snacks">
                                <i class="fas fa-cookie-bite"></i>
                                Snacks
                            </button>
                            <button class="tab-btn" data-category="bebidas">
                                <i class="fas fa-glass-cheers"></i>
                                Bebidas
                            </button>
                        </div>

                        <!-- Menu Content -->
                        <div class="menu-content">
                            <!-- Menus -->
                            <div class="category-content active" id="menus">
                                <div class="products-grid">
                                    {% for produto in produtos.menus %}
                                    <div class="product-card menu-card" data-product-id="{{ produto.id }}">
                                        <div class="product-image">
                                            {% if produto.imagem_url %}
                                            <img src="{{ url_for('static', filename=produto.imagem_url) }}" 
                                                 alt="{{ produto.produto }}" 
                                                 class="product-img"
                                                 onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                                            {% endif %}
                                            <div class="product-icon-fallback" style="display: {% if not produto.imagem_url %}flex{% else %}none{% endif %};">
                                                <i class="{{ produto.icone if produto.icone else 'fas fa-box-open' }}"></i>
                                            </div>
                                        </div>
                                        <div class="product-info">
                                            <h4>{{ produto.produto }}</h4>
                                            <p>{{ produto.descricao if produto.descricao else 'Menu completo' }}</p>
                                            <div class="product-price">€{{ "%.2f"|format(produto.preco) }}</div>
                                            <div class="quantity-controls">
                                                <button class="qty-btn" onclick="changeQuantity('{{ produto.id }}', -1)">-</button>
                                                <span class="quantity" id="{{ produto.id }}-qty">0</span>
                                                <button class="qty-btn" onclick="changeQuantity('{{ produto.id }}', 1)">+</button>
                                            </div>
                                        </div>
                                    </div>
                                    {% else %}
                                    <div class="no-products">
                                        <i class="fas fa-box-open"></i>
                                        <p>Nenhum menu disponível no momento</p>
                                    </div>
                                    {% endfor %}
                                </div>
                            </div>

                            <!-- Snacks -->
                            <div class="category-content" id="snacks">
                                <div class="products-grid">
                                    {% for produto in produtos.snacks %}
                                    <div class="product-card" data-product-id="{{ produto.id }}">
                                        <div class="product-image">
                                            {% if produto.imagem_url %}
                                            <img src="{{ url_for('static', filename=produto.imagem_url) }}" 
                                                 alt="{{ produto.produto }}" 
                                                 class="product-img"
                                                 onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                                            {% endif %}
                                            <div class="product-icon-fallback" style="display: {% if not produto.imagem_url %}flex{% else %}none{% endif %};">
                                                <i class="{{ produto.icone if produto.icone else 'fas fa-cookie-bite' }}"></i>
                                            </div>
                                        </div>
                                        <div class="product-info">
                                            <h4>{{ produto.produto }}</h4>
                                            <p>{{ produto.descricao if produto.descricao else 'Snack delicioso' }}</p>
                                            <div class="product-price">€{{ "%.2f"|format(produto.preco) }}</div>
                                            <div class="quantity-controls">
                                                <button class="qty-btn" onclick="changeQuantity('{{ produto.id }}', -1)">-</button>
                                                <span class="quantity" id="{{ produto.id }}-qty">0</span>
                                                <button class="qty-btn" onclick="changeQuantity('{{ produto.id }}', 1)">+</button>
                                            </div>
                                        </div>
                                    </div>
                                    {% else %}
                                    <div class="no-products">
                                        <i class="fas fa-cookie-bite"></i>
                                        <p>Nenhum snack disponível no momento</p>
                                    </div>
                                    {% endfor %}
                                </div>
                            </div>

                            <!-- Bebidas -->
                            <div class="category-content" id="bebidas">
                                <div class="products-grid">
                                    {% for produto in produtos.bebidas %}
                                    <div class="product-card" data-product-id="{{ produto.id }}">
                                        <div class="product-image">
                                            {% if produto.imagem_url %}
                                            <img src="{{ url_for('static', filename=produto.imagem_url) }}" 
                                                 alt="{{ produto.produto }}" 
                                                 class="product-img"
                                                 onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                                            {% endif %}
                                            <div class="product-icon-fallback" style="display: {% if not produto.imagem_url %}flex{% else %}none{% endif %};">
                                                <i class="{{ produto.icone if produto.icone else 'fas fa-glass-cheers' }}"></i>
                                            </div>
                                        </div>
                                        <div class="product-info">
                                            <h4>{{ produto.produto }}</h4>
                                            <p>{{ produto.descricao if produto.descricao else 'Bebida refrescante' }}</p>
                                            <div class="product-price">€{{ "%.2f"|format(produto.preco) }}</div>
                                            <div class="quantity-controls">
                                                <button class="qty-btn" onclick="changeQuantity('{{ produto.id }}', -1)">-</button>
                                                <span class="quantity" id="{{ produto.id }}-qty">0</span>
                                                <button class="qty-btn" onclick="changeQuantity('{{ produto.id }}', 1)">+</button>
                                            </div>
                                        </div>
                                    </div>
                                    {% else %}
                                    <div class="no-products">
                                        <i class="fas fa-glass-cheers"></i>
                                        <p>Nenhuma bebida disponível no momento</p>
                                    </div>
                                    {% endfor %}
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Cart Summary -->
                    <div class="cart-summary" id="cartSummary" style="display: none;">
                        <h4><i class="fas fa-shopping-cart"></i> Resumo do Pedido</h4>
                        <div class="cart-items" id="cartItems"></div>
                        <div class="cart-total">
                            <strong>Total Bar: €<span id="cartTotal">0.00</span></strong>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="action-buttons">
                        <button class="back-btn" onclick="goBack()">
                            <i class="fas fa-arrow-left"></i>
                            Voltar aos Lugares
                        </button>
                        
                        <!-- Formulário para toppings -->
                        <form id="resumoForm" method="GET" action="{{ url_for('selecao_toppings') }}" style="display: inline;">
                            <input type="hidden" name="filme_id" value="{{ filme_id }}">
                            <input type="hidden" name="cinema_id" value="{{ cinema_id }}">
                            <input type="hidden" name="id_tipo_sessao" value="{{ tipo_sessao_id }}">
                            <input type="hidden" name="id_horario_sessao" value="{{ horario_id }}">
                            <input type="hidden" name="data_sessao" value="{{ data_sessao }}">
                            <input type="hidden" name="lugares" value="{{ lugares_selecionados|join(',') if lugares_selecionados else '' }}">
                            <input type="hidden" name="quantidade" value="{{ lugares_selecionados|length if lugares_selecionados else 1 }}">
                            <input type="hidden" name="produtos_bar" id="produtosBarInput" value="[]">
                            
                            <button type="submit" class="continue-btn">
                                <i class="fas fa-arrow-right"></i>
                                Continuar
                            </button>
                        </form>
                        
                        <!-- Link direto como backup -->
                        <a href="{{ url_for('resumo_reserva', filme_id=filme_id, cinema_id=cinema_id, tipo_sessao_id=tipo_sessao_id, horario_id=horario_id, data_sessao=data_sessao, lugares=lugares_selecionados|join(','), quantidade=lugares_selecionados|length, produtos_bar='[]') }}" 
                           class="continue-btn" 
                           style="display: none; text-decoration: none; margin-left: 1rem;"
                           id="linkBackup">
                            <i class="fas fa-link"></i>
                            Link Direto
                        </a>
                    </div>
                </div>

            </div>
        </main>
    </div>

    <!-- Dados para JavaScript -->
    <script type="application/json" id="produtos-data">
        {
            "menus": {{ produtos.menus | tojson if produtos and produtos.menus else '[]' | safe }},
            "snacks": {{ produtos.snacks | tojson if produtos and produtos.snacks else '[]' | safe }},
            "bebidas": {{ produtos.bebidas | tojson if produtos and produtos.bebidas else '[]' | safe }}
        }
    </script>

    <script>
        console.log('=== DEBUG SELECAO BAR ===');
        
        let cart = {};
        let products = {
            menus: [],
            snacks: [],
            bebidas: []
        };
        
        // Carregar produtos do elemento JSON
        try {
            const produtosData = document.getElementById('produtos-data');
            if (produtosData) {
                const jsonText = produtosData.textContent;
                console.log('📄 JSON bruto:', jsonText);
                products = JSON.parse(jsonText);
                console.log('✅ Produtos carregados:', products);
                console.log('  - Menus:', products.menus?.length || 0);
                console.log('  - Snacks:', products.snacks?.length || 0);
                console.log('  - Bebidas:', products.bebidas?.length || 0);
                
                // Mostrar detalhes dos snacks
                if (products.snacks && products.snacks.length > 0) {
                    console.log('📦 SNACKS DETALHADOS:');
                    products.snacks.forEach(s => {
                        console.log(`   - ID ${s.id}: ${s.produto} (€${s.preco})`);
                    });
                }
            } else {
                console.error('❌ Elemento produtos-data não encontrado');
            }
        } catch(e) {
            console.error('❌ Erro ao carregar produtos:', e);
            console.error('Stack:', e.stack);
        }

        // Tab switching
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                const category = this.dataset.category;
                console.log('🔄 Mudando para categoria:', category);
                
                // Update active tab
                document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                
                // Update active content
                document.querySelectorAll('.category-content').forEach(c => c.classList.remove('active'));
                const categoryElement = document.getElementById(category);
                if (categoryElement) {
                    categoryElement.classList.add('active');
                    console.log('✅ Categoria ativada:', category);
                } else {
                    console.error('❌ Categoria não encontrada:', category);
                }
            });
        });

        // FUNÇÃO PRINCIPAL - changeQuantity
        function changeQuantity(productId, change) {
            console.log('🔧 changeQuantity chamado:', {productId, change, tipo: typeof productId});
            
            // Garantir que productId é string
            productId = String(productId);
            
            if (!cart[productId]) {
                cart[productId] = 0;
                console.log('   Inicializando carrinho para produto:', productId);
            }
            
            cart[productId] += change;
            if (cart[productId] < 0) cart[productId] = 0;
            
            console.log('   Nova quantidade:', cart[productId]);
            console.log('   Carrinho completo:', cart);
            
            const qtyElement = document.getElementById(productId + '-qty');
            if (qtyElement) {
                qtyElement.textContent = cart[productId];
                console.log('✅ Quantidade atualizada no DOM');
            } else {
                console.error('❌ Elemento não encontrado:', productId + '-qty');
                console.log('   Tentando encontrar elemento...');
                const allQtyElements = document.querySelectorAll('[id$="-qty"]');
                console.log('   Elementos de quantidade encontrados:', allQtyElements.length);
                allQtyElements.forEach(el => console.log('      -', el.id));
            }
            
            updateCartSummary();
        }
        
        // Tornar função global
        window.changeQuantity = changeQuantity;
        
        function updateCartSummary() {
            const cartItems = document.getElementById('cartItems');
            const cartTotal = document.getElementById('cartTotal');
            const cartSummary = document.getElementById('cartSummary');
            const produtosBarInput = document.getElementById('produtosBarInput');
            const skipBtn = document.querySelector('.skip-btn');
            
            let total = 0;
            let itemsHtml = '';
            let hasItems = false;
            
            // Preparar produtos para o formulário
            const produtosSelecionados = [];
            
            for (let productId in cart) {
                if (cart[productId] > 0) {
                    hasItems = true;
                    
                    // Adicionar ao array de produtos selecionados
                    produtosSelecionados.push({
                        id: productId,
                        quantidade: cart[productId]
                    });
                    
                    // Encontrar produto nas categorias
                    let product = null;
                    for (let categoria in products) {
                        if (products[categoria] && Array.isArray(products[categoria])) {
                            product = products[categoria].find(p => p.id == productId);
                            if (product) break;
                        }
                    }
                    
                    if (product) {
                        const subtotal = product.preco * cart[productId];
                        total += subtotal;
                        
                        itemsHtml += `
                            <div class="cart-item">
                                <span>${product.produto} x${cart[productId]}</span>
                                <span>€${subtotal.toFixed(2)}</span>
                            </div>
                        `;
                    }
                }
            }
            
            if (cartItems) cartItems.innerHTML = itemsHtml;
            if (cartTotal) cartTotal.textContent = total.toFixed(2);
            if (cartSummary) cartSummary.style.display = hasItems ? 'block' : 'none';
            
            // Atualizar texto do botão skip
            if (skipBtn) {
                if (hasItems) {
                    skipBtn.innerHTML = '<i class="fas fa-arrow-right"></i> Continuar';
                } else {
                    skipBtn.innerHTML = '<i class="fas fa-forward"></i> Não, obrigado. Continuar sem produtos do bar';
                }
            }
            
            // Atualizar campo hidden do formulário
            if (produtosBarInput) {
                produtosBarInput.value = JSON.stringify(produtosSelecionados);
                console.log('Campo hidden atualizado:', produtosBarInput.value);
            }
        }

        // Configurar event listeners quando DOM carregar
        document.addEventListener('DOMContentLoaded', function() {
            console.log('🚀 DOM carregado, configurando event listeners...');
            
            // Testar se os botões existem
            const allButtons = document.querySelectorAll('.qty-btn');
            console.log(`🔘 Total de botões encontrados: ${allButtons.length}`);
            
            // Verificar botões das pipocas salgadas (ID 1)
            const pipocasBtn = document.querySelector('button[onclick*="changeQuantity(\'1\'"]');
            if (pipocasBtn) {
                console.log('✅ Botão das Pipocas Salgadas encontrado');
            } else {
                console.error('❌ Botão das Pipocas Salgadas NÃO encontrado');
            }
            
            const form = document.getElementById('resumoForm');
            const linkBackup = document.getElementById('linkBackup');
            
            if (form) {
                form.addEventListener('submit', function(e) {
                    console.log('Formulário sendo submetido...');
                    
                    // Atualizar produtos antes da submissão
                    const produtosSelecionados = [];
                    for (let productId in cart) {
                        if (cart[productId] > 0) {
                            produtosSelecionados.push({
                                id: productId,
                                quantidade: cart[productId]
                            });
                        }
                    }
                    
                    const produtosInput = document.getElementById('produtosBarInput');
                    if (produtosInput) {
                        produtosInput.value = JSON.stringify(produtosSelecionados);
                        console.log('Produtos finais:', produtosInput.value);
                    }
                    
                    // Mostrar link de backup após 3 segundos se não redirecionar
                    setTimeout(function() {
                        if (linkBackup) {
                            linkBackup.style.display = 'inline-flex';
                            console.log('Mostrando link de backup...');
                        }
                    }, 3000);
                });
            }
        });

        function goBack() {
            window.history.back();
        }
    </script>
</body>
</html>