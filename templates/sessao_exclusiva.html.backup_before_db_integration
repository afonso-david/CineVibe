    <!-- Modal de Reserva Exclusiva -->
    <div id="reservaExclusivaModal" class="modal-reserva-exclusiva" style="display: none;">
        <div class="modal-content-reserva">
            <div class="modal-header-reserva">
                <h2>Reservar Experiência Exclusiva</h2>
                <button class="btn-close-reserva" onclick="fecharModalReserva()">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </div>
            
            <div class="modal-body-reserva">
                <form id="formReservaExclusiva">
                    <!-- Informações da Sala -->
                    <div class="sala-info">
                        <h3 id="salaNome">Sala VIP Premium</h3>
                        <div class="sala-preco">
                            <span class="preco-valor" id="salaPreco">€800</span>
                            <span class="preco-periodo">por sessão</span>
                        </div>
                    </div>

                    <!-- Seleção de Filme -->
                    <div class="form-group-reserva">
                        <label for="filmeSelect">Escolha o Filme</label>
                        <select id="filmeSelect" name="filme" required>
                            <option value="">Selecione um filme...</option>
                        </select>
                    </div>

                    <!-- Data da Sessão -->
                    <div class="form-group-reserva">
                        <label for="dataSelect">Data da Sessão</label>
                        <input type="date" id="dataSelect" name="data" required min="">
                    </div>

                    <!-- Hora da Sessão -->
                    <div class="form-group-reserva">
                        <label for="horaSelect">Hora da Sessão</label>
                        <select id="horaSelect" name="hora" required>
                            <option value="">Selecione um horário...</option>
                            <option value="14:00">14:00</option>
                            <option value="16:30">16:30</option>
                            <option value="19:00">19:00</option>
                            <option value="21:30">21:30</option>
                            <option value="00:00">00:00 (Sessão Madrugada)</option>
                        </select>
                    </div>

                    <!-- Número de Pessoas -->
                    <div class="form-group-reserva">
                        <label for="numPessoas">Número de Pessoas</label>
                        <select id="numPessoas" name="pessoas" required>
                            <option value="">Quantas pessoas?</option>
                            <option value="1">1 pessoa</option>
                            <option value="2">2 pessoas</option>
                            <option value="3">3 pessoas</option>
                            <option value="4">4 pessoas</option>
                            <option value="5">5 pessoas</option>
                            <option value="6">6 pessoas</option>
                            <option value="7">7 pessoas</option>
                            <option value="8">8 pessoas</option>
                            <option value="9">9 pessoas</option>
                            <option value="10">10 pessoas</option>
                        </select>
                    </div>

                    <!-- Dados do Cliente (se não logado) -->
                    <div id="dadosCliente" style="display: none;">
                        <h4>Dados de Contacto</h4>
                        <div class="form-group-reserva">
                            <label for="nomeCliente">Nome Completo</label>
                            <input type="text" id="nomeCliente" name="nome" placeholder="O seu nome completo">
                        </div>
                        <div class="form-group-reserva">
                            <label for="emailCliente">Email</label>
                            <input type="email" id="emailCliente" name="email" placeholder="O seu email">
                        </div>
                        <div class="form-group-reserva">
                            <label for="telefoneCliente">Telefone</label>
                            <input type="tel" id="telefoneCliente" name="telefone" placeholder="O seu telefone">
                        </div>
                    </div>

                    <!-- Resumo do Pedido -->
                    <div class="resumo-pedido">
                        <h4>Resumo do Pedido</h4>
                        <div class="resumo-item">
                            <span>Sala:</span>
                            <span id="resumoSala">-</span>
                        </div>
                        <div class="resumo-item">
                            <span>Filme:</span>
                            <span id="resumoFilme">-</span>
                        </div>
                        <div class="resumo-item">
                            <span>Data e Hora:</span>
                            <span id="resumoDataHora">-</span>
                        </div>
                        <div class="resumo-item">
                            <span>Pessoas:</span>
                            <span id="resumoPessoas">-</span>
                        </div>
                        <div class="resumo-item total">
                            <span>Total:</span>
                            <span id="resumoTotal">€0</span>
                        </div>
                    </div>
                </form>
            </div>
            
            <div class="modal-footer-reserva">
                <button class="btn-cancelar-reserva" onclick="fecharModalReserva()">Cancelar</button>
                <button class="btn-confirmar-reserva" onclick="prosseguirPagamento()">Prosseguir para Pagamento</button>
            </div>
        </div>
    </div>

    <style>
        .modal-reserva-exclusiva {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.8);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 1000;
            overflow-y: auto;
        }
        
        .modal-content-reserva {
            background: linear-gradient(135deg, #1B263B, #2C3E50);
            border-radius: 20px;
            width: 90%;
            max-width: 600px;
            max-height: 90vh;
            overflow-y: auto;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
            border: 2px solid rgba(255, 214, 10, 0.3);
        }
        
        .modal-header-reserva {
            background: linear-gradient(135deg, #FFD60A, #FFA500);
            color: #1a1a1a;
            padding: 20px 30px;
            border-radius: 18px 18px 0 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .modal-header-reserva h2 {
            margin: 0;
            font-size: 1.5rem;
            font-weight: 700;
        }
        
        .btn-close-reserva {
            background: none;
            border: none;
            color: #1a1a1a;
            cursor: pointer;
            padding: 5px;
            border-radius: 50%;
            transition: all 0.3s ease;
        }
        
        .btn-close-reserva:hover {
            background: rgba(26, 26, 26, 0.1);
            transform: scale(1.1);
        }
        
        .modal-body-reserva {
            padding: 30px;
            color: white;
        }
        
        .sala-info {
            text-align: center;
            margin-bottom: 30px;
            padding: 20px;
            background: rgba(255, 214, 10, 0.1);
            border-radius: 15px;
            border: 1px solid rgba(255, 214, 10, 0.3);
        }
        
        .sala-info h3 {
            color: #FFD60A;
            margin: 0 0 10px 0;
            font-size: 1.3rem;
        }
        
        .sala-preco {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }
        
        .preco-valor {
            font-size: 2rem;
            font-weight: 700;
            color: #FFD60A;
        }
        
        .preco-periodo {
            color: rgba(255, 255, 255, 0.7);
            font-size: 0.9rem;
        }
        
        .form-group-reserva {
            margin-bottom: 20px;
        }
        
        .form-group-reserva label {
            display: block;
            color: #FFD60A;
            font-weight: 600;
            margin-bottom: 8px;
            font-size: 14px;
        }
        
        .form-group-reserva select,
        .form-group-reserva input {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid rgba(255, 214, 10, 0.3);
            border-radius: 10px;
            background: rgba(255, 255, 255, 0.1);
            color: white;
            font-size: 16px;
            transition: all 0.3s ease;
            box-sizing: border-box;
        }
        
        .form-group-reserva select:focus,
        .form-group-reserva input:focus {
            outline: none;
            border-color: #FFD60A;
            box-shadow: 0 0 0 3px rgba(255, 214, 10, 0.2);
        }
        
        .form-group-reserva option {
            background: #2C3E50;
            color: white;
        }
        
        #dadosCliente {
            margin-top: 30px;
            padding: 20px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 15px;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        
        #dadosCliente h4 {
            color: #FFD60A;
            margin: 0 0 20px 0;
            font-size: 1.1rem;
        }
        
        .resumo-pedido {
            margin-top: 30px;
            padding: 20px;
            background: rgba(255, 214, 10, 0.1);
            border-radius: 15px;
            border: 1px solid rgba(255, 214, 10, 0.3);
        }
        
        .resumo-pedido h4 {
            color: #FFD60A;
            margin: 0 0 15px 0;
            font-size: 1.1rem;
        }
        
        .resumo-item {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
            color: rgba(255, 255, 255, 0.9);
        }
        
        .resumo-item.total {
            border-top: 1px solid rgba(255, 214, 10, 0.3);
            padding-top: 10px;
            margin-top: 10px;
            font-weight: 700;
            font-size: 1.1rem;
            color: #FFD60A;
        }
        
        .modal-footer-reserva {
            padding: 20px 30px 30px;
            display: flex;
            gap: 15px;
            justify-content: flex-end;
        }
        
        .btn-cancelar-reserva {
            background: rgba(244, 67, 54, 0.8);
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 25px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .btn-cancelar-reserva:hover {
            background: rgba(244, 67, 54, 1);
            transform: translateY(-2px);
        }
        
        .btn-confirmar-reserva {
            background: linear-gradient(135deg, #FFD60A, #FFA500);
            color: #1a1a1a;
            border: none;
            padding: 12px 24px;
            border-radius: 25px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .btn-confirmar-reserva:hover {
            background: linear-gradient(135deg, #FFA500, #FF8C00);
            transform: translateY(-2px);
        }
        
        .btn-confirmar-reserva:disabled {
            background: rgba(255, 214, 10, 0.5);
            cursor: not-allowed;
            transform: none;
        }
    </style>

    <script>
        let tipoSalaAtual = '';
        let precoSalaAtual = 0;
        let loggedIn = {{ 'true' if logged_in else 'false' }};
        let userData = {
            nome: '{{ nome }}',
            email: '{{ email }}',
            telefone: '{{ telefone }}'
        };

        // Função para abrir modal de reserva
        function openReservaModal(tipoSala, preco) {
            tipoSalaAtual = tipoSala;
            precoSalaAtual = preco;
            
            // Configurar informações da sala
            const salaNames = {
                'intimista': 'Sala Intimista',
                'vip': 'Sala Vip',
                'premium': 'Sala Premium'
            };
            
            document.getElementById('salaNome').textContent = salaNames[tipoSala] || 'Sala Exclusiva';
            document.getElementById('salaPreco').textContent = '€' + preco;
            document.getElementById('resumoSala').textContent = salaNames[tipoSala] || 'Sala Exclusiva';
            
            // Configurar data mínima (hoje)
            const hoje = new Date();
            const dataMinima = hoje.toISOString().split('T')[0];
            document.getElementById('dataSelect').min = dataMinima;
            
            // Mostrar/ocultar dados do cliente baseado no login
            const dadosCliente = document.getElementById('dadosCliente');
            if (!loggedIn) {
                dadosCliente.style.display = 'block';
                document.getElementById('nomeCliente').required = true;
                document.getElementById('emailCliente').required = true;
                document.getElementById('telefoneCliente').required = true;
            } else {
                dadosCliente.style.display = 'none';
                document.getElementById('nomeCliente').required = false;
                document.getElementById('emailCliente').required = false;
                document.getElementById('telefoneCliente').required = false;
            }
            
            // Carregar filmes disponíveis
            carregarFilmes();
            
            // Mostrar modal
            document.getElementById('reservaExclusivaModal').style.display = 'flex';
        }

        // Função para fechar modal
        function fecharModalReserva() {
            document.getElementById('reservaExclusivaModal').style.display = 'none';
            limparFormulario();
        }

        // Função para carregar filmes
        function carregarFilmes() {
            fetch('/api/filmes_disponiveis')
                .then(response => response.json())
                .then(data => {
                    const select = document.getElementById('filmeSelect');
                    select.innerHTML = '<option value="">Selecione um filme...</option>';
                    
                    if (data && Array.isArray(data)) {
                        data.forEach(filme => {
                            const option = document.createElement('option');
                            option.value = filme.id;
                            option.textContent = filme.titulo;
                            option.dataset.nome = filme.titulo;
                            select.appendChild(option);
                        });
                    }
                })
                .catch(error => {
                    console.error('Erro ao carregar filmes:', error);
                });
        }

        // Função para atualizar resumo
        function atualizarResumo() {
            const filme = document.getElementById('filmeSelect');
            const data = document.getElementById('dataSelect').value;
            const hora = document.getElementById('horaSelect').value;
            const pessoas = document.getElementById('numPessoas').value;
            
            // Atualizar filme
            if (filme.value) {
                document.getElementById('resumoFilme').textContent = filme.options[filme.selectedIndex].textContent;
            } else {
                document.getElementById('resumoFilme').textContent = '-';
            }
            
            // Atualizar data e hora
            if (data && hora) {
                const dataFormatada = new Date(data).toLocaleDateString('pt-PT');
                document.getElementById('resumoDataHora').textContent = dataFormatada + ' às ' + hora;
            } else {
                document.getElementById('resumoDataHora').textContent = '-';
            }
            
            // Atualizar pessoas
            if (pessoas) {
                document.getElementById('resumoPessoas').textContent = pessoas + (pessoas == 1 ? ' pessoa' : ' pessoas');
            } else {
                document.getElementById('resumoPessoas').textContent = '-';
            }
            
            // Atualizar total
            document.getElementById('resumoTotal').textContent = '€' + precoSalaAtual;
        }

        // Event listeners para atualizar resumo
        document.addEventListener('DOMContentLoaded', function() {
            const campos = ['filmeSelect', 'dataSelect', 'horaSelect', 'numPessoas'];
            campos.forEach(campo => {
                const elemento = document.getElementById(campo);
                if (elemento) {
                    elemento.addEventListener('change', atualizarResumo);
                }
            });
        });

        // Função para limpar formulário
        function limparFormulario() {
            document.getElementById('formReservaExclusiva').reset();
            atualizarResumo();
        }

        // Função para prosseguir para pagamento
        function prosseguirPagamento() {
            const form = document.getElementById('formReservaExclusiva');
            const formData = new FormData(form);
            
            // Validar campos obrigatórios
            const filme = formData.get('filme');
            const data = formData.get('data');
            const hora = formData.get('hora');
            const pessoas = formData.get('pessoas');
            
            if (!filme || !data || !hora || !pessoas) {
                alert('Por favor, preencha todos os campos obrigatórios.');
                return;
            }
            
            // Validar dados do cliente se não logado
            if (!loggedIn) {
                const nome = formData.get('nome');
                const email = formData.get('email');
                const telefone = formData.get('telefone');
                
                if (!nome || !email || !telefone) {
                    alert('Por favor, preencha todos os seus dados de contacto.');
                    return;
                }
            }
            
            // Preparar dados da reserva
            const dadosReserva = {
                tipo_sala: tipoSalaAtual,
                filme_id: filme,
                filme_nome: document.getElementById('filmeSelect').options[document.getElementById('filmeSelect').selectedIndex].textContent,
                data_sessao: data,
                hora_sessao: hora,
                num_pessoas: parseInt(pessoas),
                total: precoSalaAtual,
                nome_cliente: loggedIn ? userData.nome : formData.get('nome'),
                email_cliente: loggedIn ? userData.email : formData.get('email'),
                telefone_cliente: loggedIn ? userData.telefone : formData.get('telefone')
            };
            
            // Redirecionar para página de pagamento
            sessionStorage.setItem('dadosReservaExclusiva', JSON.stringify(dadosReserva));
            window.location.href = '/pagamento-exclusivo';
        }

        // Função para scroll suave
        function scrollToSalas() {
            document.getElementById('salas').scrollIntoView({ behavior: 'smooth' });
        }

        // Fechar modal com ESC
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                fecharModalReserva();
            }
        });
    </script>
</body>
</html>